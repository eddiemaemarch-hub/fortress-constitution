//@version=6
// Rudy v2 — BTC/USD Moonshot LEAP Strategy (adapted from MSTR Moonshot)
// Same laddered trailing stop logic, cycle timing, and entry conditions
// Applied directly to BTCUSD chart — no mNAV premium or MSTR correlation needed
// Apply to: BTCUSD daily chart (weekly is king, daily for entries)
strategy("Rudy BTC Moonshot v1", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=5, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.5, slippage=5, pyramiding=3)

// ══════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════

// --- BTC Indicator Parameters ---
p_ema_entry     = input.int(21,  "Entry EMA",              group="BTC Indicators")
p_ema_exit      = input.int(50,  "Exit EMA",               group="BTC Indicators")
p_ema_200       = input.int(200, "200 EMA (Key Level)",     group="BTC Indicators")
p_rsi_len       = input.int(14,  "RSI Length",              group="BTC Indicators")
p_rsi_lo        = input.float(40.0, "RSI Floor",            group="BTC Indicators")
p_rsi_hi        = input.float(75.0, "RSI Ceiling",          group="BTC Indicators")
p_vol_avg_len   = input.int(20,  "Volume Avg Length",       group="BTC Indicators")
p_vol_mult      = input.float(1.5, "Volume Surge Multiple", group="BTC Indicators")
p_mom_len       = input.int(5,   "Momentum Lookback Bars",  group="BTC Indicators")
p_mom_thresh    = input.float(3.0, "Momentum Threshold %",  group="BTC Indicators")

// --- Parabolic SAR ---
p_sar_start     = input.float(0.02, "SAR Start",           group="Parabolic SAR")
p_sar_inc       = input.float(0.02, "SAR Increment",       group="Parabolic SAR")
p_sar_max       = input.float(0.20, "SAR Max",             group="Parabolic SAR")

// --- MACD ---
p_macd_fast     = input.int(12,  "MACD Fast",              group="MACD")
p_macd_slow     = input.int(26,  "MACD Slow",              group="MACD")
p_macd_sig      = input.int(9,   "MACD Signal",            group="MACD")

// --- Stochastic RSI ---
p_stoch_len     = input.int(14,  "Stoch RSI Length",        group="Stochastic RSI")
p_stoch_k       = input.int(3,   "Stoch K Smooth",          group="Stochastic RSI")
p_stoch_d       = input.int(3,   "Stoch D Smooth",          group="Stochastic RSI")

// --- Cycle Timing ---
p_use_cycle     = input.bool(true,  "Enable Cycle Timing Filter",  group="Cycle")
p_entry_month_start = input.int(10, "Entry Window Start Month",    group="Cycle", minval=1, maxval=12)
p_entry_month_end   = input.int(11, "Entry Window End Month",      group="Cycle", minval=1, maxval=12)
p_halving_year  = input.int(2024,   "Last BTC Halving Year",       group="Cycle")

// --- Risk / Hold Parameters ---
p_max_hold_bars = input.int(567, "Max Hold Bars (~27mo daily)",    group="Risk")
p_target_mult   = input.float(5.0, "Target Return Multiple",       group="Risk")

// --- 200-Week MA Override ---
p_use_200w      = input.bool(true, "200-Week MA Override",         group="Fallbacks")
p_weekly_tf     = input.string("W", "Weekly Timeframe",            group="Fallbacks")
p_200w_len      = input.int(200, "200-Week MA Length",              group="Fallbacks")

// --- Laddered Trailing Stop (Constitution v45.0) ---
p_lad_t1_gain   = input.float(100,  "Tier 1: Trail at +% (2x)",   group="Trail Stop")
p_lad_t1_trail  = input.float(25.0, "Tier 1: Trail %",            group="Trail Stop")
p_lad_t2_gain   = input.float(200,  "Tier 2: Trail at +% (3x)",   group="Trail Stop")
p_lad_t2_trail  = input.float(20.0, "Tier 2: Trail %",            group="Trail Stop")
p_lad_t3_gain   = input.float(400,  "Tier 3: Trail at +% (5x)",   group="Trail Stop")
p_lad_t3_trail  = input.float(15.0, "Tier 3: Trail %",            group="Trail Stop")
p_lad_t4_gain   = input.float(900,  "Tier 4: Trail at +% (10x)",  group="Trail Stop")
p_lad_t4_trail  = input.float(12.0, "Tier 4: Trail %",            group="Trail Stop")
p_lad_t5_gain   = input.float(1900, "Tier 5: Trail at +% (20x)",  group="Trail Stop")
p_lad_t5_trail  = input.float(10.0, "Tier 5: Trail % LOCK",       group="Trail Stop")

// --- Tiered Profit Taking ---
pt1_pct         = input.float(200,  "PT1 at +% (3x)",             group="Profit Taking")
pt1_sell        = input.float(25,   "PT1 Sell %",                  group="Profit Taking")
pt2_pct         = input.float(400,  "PT2 at +% (5x)",             group="Profit Taking")
pt2_sell        = input.float(25,   "PT2 Sell %",                  group="Profit Taking")
pt3_pct         = input.float(900,  "PT3 at +% (10x)",            group="Profit Taking")
pt3_sell        = input.float(25,   "PT3 Sell %",                  group="Profit Taking")
pt4_pct         = input.float(1900, "PT4 at +% (20x)",            group="Profit Taking")
pt4_sell        = input.float(25,   "PT4 Sell %",                  group="Profit Taking")

// --- Dashboard ---
p_show_dash     = input.bool(true, "Show Dashboard",               group="Display")
p_show_bg       = input.bool(true, "Show Regime Background",       group="Display")
p_show_sar      = input.bool(true, "Show Parabolic SAR",           group="Display")

// ══════════════════════════════════════════════════════════════════════
// BTC 200-WEEK MA — Ultimate Cycle Support
// ══════════════════════════════════════════════════════════════════════

ma_200w = request.security(syminfo.tickerid, p_weekly_tf, ta.sma(close, p_200w_len), barmerge.gaps_off, barmerge.lookahead_off)
below_200w = close < ma_200w
ma_200w_break = p_use_200w and below_200w

// ══════════════════════════════════════════════════════════════════════
// BTC REGIME — Using chart data directly (no external request needed)
// ══════════════════════════════════════════════════════════════════════

ema_entry   = ta.ema(close, p_ema_entry)
ema_exit    = ta.ema(close, p_ema_exit)
ema_200     = ta.ema(close, p_ema_200)
sma_200     = ta.sma(close, 200)
sma_50      = ta.sma(close, 50)
rsi_val     = ta.rsi(close, p_rsi_len)
vol_avg     = ta.sma(volume, p_vol_avg_len)
vol_ratio   = volume / vol_avg
mom_pct     = (close - close[p_mom_len]) / close[p_mom_len] * 100

// Regime: BTC above 200 SMA + 50 EMA > 200 SMA = BULL
btc_above_200 = close > sma_200
btc_golden    = ta.ema(close, 50) > sma_200
btc_death_cross = ta.crossunder(sma_50, sma_200)

var string btc_regime = "NEUTRAL"
if btc_above_200 and btc_golden
    btc_regime := "BULL"
else if not btc_above_200 and not btc_golden
    btc_regime := "BEAR"
else
    btc_regime := "NEUTRAL"

is_bull = btc_regime == "BULL"
is_bear = btc_regime == "BEAR"

// Golden Cross detection
golden_cross = ta.crossover(ema_exit, ema_200)
above_200 = close > ema_200

// ══════════════════════════════════════════════════════════════════════
// PARABOLIC SAR
// ══════════════════════════════════════════════════════════════════════

sar_val = ta.sar(p_sar_start, p_sar_inc, p_sar_max)
sar_bullish = close > sar_val
sar_flip_bull = sar_bullish and not sar_bullish[1]
sar_flip_bear = not sar_bullish and sar_bullish[1]

// ══════════════════════════════════════════════════════════════════════
// MACD
// ══════════════════════════════════════════════════════════════════════

[macd_line, macd_signal, macd_hist] = ta.macd(close, p_macd_fast, p_macd_slow, p_macd_sig)
macd_bull_cross = ta.crossover(macd_line, macd_signal)
macd_bear_cross = ta.crossunder(macd_line, macd_signal)
macd_bullish = macd_line > macd_signal
macd_positive = macd_line > 0

// MACD divergence (price higher high, MACD lower high = bearish)
price_hh = high > ta.highest(high, 20)[1]
macd_lh = macd_line < ta.highest(macd_line, 20)[1]
macd_bearish_div = price_hh and macd_lh and strategy.opentrades > 0

// ══════════════════════════════════════════════════════════════════════
// STOCHASTIC RSI
// ══════════════════════════════════════════════════════════════════════

stoch_rsi_raw = ta.rsi(close, p_stoch_len)
stoch_k_raw = ta.sma(ta.stoch(stoch_rsi_raw, stoch_rsi_raw, stoch_rsi_raw, p_stoch_len), p_stoch_k)
stoch_d_raw = ta.sma(stoch_k_raw, p_stoch_d)
stoch_oversold = stoch_k_raw < 20
stoch_overbought = stoch_k_raw > 80

// ══════════════════════════════════════════════════════════════════════
// CYCLE PHASE
// ══════════════════════════════════════════════════════════════════════

years_since_halving = year - p_halving_year
cycle_year = years_since_halving % 4
var string cycle_phase = "ACCUMULATION"
if cycle_year == 0
    cycle_phase := "ACCUMULATION"
else if cycle_year == 1
    cycle_phase := "MARKUP"
else if cycle_year == 2
    cycle_phase := "EUPHORIA"
else
    cycle_phase := "DISTRIBUTION"

in_entry_window = p_use_cycle ? (month >= p_entry_month_start and month <= p_entry_month_end) : true
is_post_halving = cycle_year == 0 or cycle_year == 1

// ══════════════════════════════════════════════════════════════════════
// ENTRY CONDITIONS (6 core)
// ══════════════════════════════════════════════════════════════════════

cond_price_above_ema = close > ema_entry
cond_volume_surge    = vol_ratio > p_vol_mult
cond_rsi_zone        = rsi_val >= p_rsi_lo and rsi_val <= p_rsi_hi
cond_momentum        = mom_pct > p_mom_thresh
cond_btc_bull        = is_bull
cond_cycle           = p_use_cycle ? (in_entry_window and is_post_halving) : true

all_entry = cond_price_above_ema and cond_volume_surge and cond_rsi_zone and cond_momentum and cond_btc_bull and cond_cycle

// Supporting confirmations
confirm_sar = sar_bullish
confirm_macd = macd_bullish
confirm_golden = above_200

entry_score = (cond_price_above_ema ? 1 : 0) + (cond_volume_surge ? 1 : 0) + (cond_rsi_zone ? 1 : 0) + (cond_momentum ? 1 : 0) + (cond_btc_bull ? 1 : 0) + (cond_cycle ? 1 : 0)
confirm_score = (confirm_sar ? 1 : 0) + (confirm_macd ? 1 : 0) + (confirm_golden ? 1 : 0)

// ══════════════════════════════════════════════════════════════════════
// EXIT CONDITIONS
// ══════════════════════════════════════════════════════════════════════

entry_px       = strategy.opentrades > 0 ? strategy.opentrades.entry_price(strategy.opentrades - 1) : na
current_pnl_pct = strategy.opentrades > 0 ? (close - entry_px) / entry_px * 100 : 0.0

// Death cross = hard exit
exit_death_cross = btc_death_cross

// 200-week MA break
exit_200w = ma_200w_break and strategy.opentrades > 0

// Below EMA 50 + volume spike + losing = full exit
partial_exit_warning = close < ema_exit and vol_ratio > p_vol_mult and current_pnl_pct < 0

// Max hold
bars_in_trade  = strategy.opentrades > 0 ? bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1) : 0
exit_max_hold  = bars_in_trade >= p_max_hold_bars and strategy.opentrades > 0

// Target reached
exit_target    = strategy.opentrades > 0 and close >= entry_px * p_target_mult

// MACD divergence warning
macd_div_warning = macd_bearish_div and current_pnl_pct > 200

// ══════════════════════════════════════════════════════════════════════
// LADDERED TRAILING STOP (Constitution v45.0)
// ══════════════════════════════════════════════════════════════════════

var float pos_hwm = 0.0
if strategy.opentrades > 0
    pos_hwm := math.max(pos_hwm, high)
if strategy.opentrades == 0
    pos_hwm := 0.0
hwm_val = pos_hwm > 0 ? pos_hwm : close
gain_pct = current_pnl_pct

float peak_gain_pct = strategy.opentrades > 0 and entry_px > 0 ? (pos_hwm - entry_px) / entry_px * 100 : 0.0

var float ladder_trail_pct = 0.0
var string ladder_tier = "NONE (< +" + str.tostring(p_lad_t1_gain, "#") + "%)"
if peak_gain_pct >= p_lad_t5_gain
    ladder_trail_pct := p_lad_t5_trail
    ladder_tier := "20x+ | " + str.tostring(p_lad_t5_trail,"#") + "% LOCK"
else if peak_gain_pct >= p_lad_t4_gain
    ladder_trail_pct := p_lad_t4_trail
    ladder_tier := "10x+ | " + str.tostring(p_lad_t4_trail,"#") + "% trail"
else if peak_gain_pct >= p_lad_t3_gain
    ladder_trail_pct := p_lad_t3_trail
    ladder_tier := "5x+ | " + str.tostring(p_lad_t3_trail,"#") + "% trail"
else if peak_gain_pct >= p_lad_t2_gain
    ladder_trail_pct := p_lad_t2_trail
    ladder_tier := "3x+ | " + str.tostring(p_lad_t2_trail,"#") + "% trail"
else if peak_gain_pct >= p_lad_t1_gain
    ladder_trail_pct := p_lad_t1_trail
    ladder_tier := "2x+ | " + str.tostring(p_lad_t1_trail,"#") + "% trail"
else
    ladder_trail_pct := 0.0
    ladder_tier := "NONE (< +" + str.tostring(p_lad_t1_gain, "#") + "%)"

ladder_trail_active = strategy.opentrades > 0 and peak_gain_pct >= p_lad_t1_gain
ladder_trail_stop = ladder_trail_active ? pos_hwm * (1 - ladder_trail_pct / 100) : na
ladder_trail_triggered = ladder_trail_active and close < ladder_trail_stop

// ══════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ══════════════════════════════════════════════════════════════════════

var bool pt1_hit = false
var bool pt2_hit = false
var bool pt3_hit = false
var bool pt4_hit = false

if strategy.opentrades > 0
    if gain_pct >= pt1_pct and not pt1_hit
        strategy.close("BTC_MOON", comment="PT1 3x +" + str.tostring(pt1_pct,"#") + "%", qty_percent=pt1_sell)
        pt1_hit := true
    if gain_pct >= pt2_pct and not pt2_hit
        strategy.close("BTC_MOON", comment="PT2 5x +" + str.tostring(pt2_pct,"#") + "%", qty_percent=pt2_sell)
        pt2_hit := true
    if gain_pct >= pt3_pct and not pt3_hit
        strategy.close("BTC_MOON", comment="PT3 10x +" + str.tostring(pt3_pct,"#") + "%", qty_percent=pt3_sell)
        pt3_hit := true
    if gain_pct >= pt4_pct and not pt4_hit
        strategy.close("BTC_MOON", comment="PT4 20x +" + str.tostring(pt4_pct,"#") + "%", qty_percent=pt4_sell)
        pt4_hit := true

if strategy.opentrades == 0
    pt1_hit := false
    pt2_hit := false
    pt3_hit := false
    pt4_hit := false

if all_entry and strategy.opentrades == 0
    strategy.entry("BTC_MOON", strategy.long, comment="BTC ENTRY")

// Hard exits
if exit_death_cross and strategy.opentrades > 0
    strategy.close_all(comment="DEATH CROSS")

if exit_max_hold
    strategy.close_all(comment="MAX HOLD")

if exit_target
    strategy.close_all(comment="TARGET HIT")

if partial_exit_warning and strategy.opentrades > 0 and not exit_death_cross
    strategy.close_all(comment="BELOW EMA50 + LOSING")

// 200-week MA break
if exit_200w and current_pnl_pct < 0
    strategy.close_all(comment="< 200W MA + LOSING")
else if exit_200w and current_pnl_pct > 0
    strategy.close("BTC_MOON", comment="< 200W MA PARTIAL", qty_percent=50)

// Laddered trailing stop
if ladder_trail_triggered
    strategy.close_all(comment="LADDER TRAIL STOP")

// ══════════════════════════════════════════════════════════════════════
// PLOTS & VISUALS
// ══════════════════════════════════════════════════════════════════════

plot(ema_entry, "EMA 21", color=color.new(color.aqua, 0), linewidth=1)
plot(ema_exit,  "EMA 50", color=color.new(color.orange, 0), linewidth=1)
plot(ema_200,   "EMA 200", color=color.new(color.white, 30), linewidth=2, style=plot.style_cross)

plot(p_show_sar ? sar_val : na, "Parabolic SAR", color=sar_bullish ? color.new(color.lime, 30) : color.new(color.red, 30), style=plot.style_circles, linewidth=1)

// Regime background
bull_bg = p_show_bg and is_bull  ? color.new(color.green, 92) : na
bear_bg = p_show_bg and is_bear  ? color.new(color.red, 92)   : na
neut_bg = p_show_bg and btc_regime == "NEUTRAL" ? color.new(color.yellow, 95) : na
bgcolor(bull_bg, title="Bull Regime BG")
bgcolor(bear_bg, title="Bear Regime BG")
bgcolor(neut_bg, title="Neutral Regime BG")

bgcolor(p_use_cycle and in_entry_window and is_post_halving ? color.new(color.lime, 94) : na, title="Cycle Entry Window")
bgcolor(ma_200w_break and strategy.opentrades > 0 ? color.new(color.red, 80) : na, title="200W Break")

// Exit shapes
plotshape(exit_200w and strategy.opentrades > 0, title="200W Exit", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.normal, text="200W!")

// Ladder trail stop line
plot(ladder_trail_active ? ladder_trail_stop : na, "Ladder Trail Stop", color=color.new(#FF00FF, 0), linewidth=2, style=plot.style_stepline)

// Entry/exit arrows
plotshape(all_entry and strategy.opentrades == 0, title="BUY Signal", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.normal, text="BTC MOON")
plotshape(exit_death_cross and strategy.opentrades > 0, title="DEATH CROSS", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.normal, text="DC EXIT")
plotshape(partial_exit_warning and strategy.opentrades > 0 and not exit_death_cross, title="EMA50 Exit", style=shape.xcross, location=location.abovebar, color=color.orange, size=size.small, text="EMA50 EXIT")
plotshape(exit_target, title="TARGET HIT", style=shape.flag, location=location.abovebar, color=color.fuchsia, size=size.normal, text="TARGET!")
plotshape(macd_div_warning, title="MACD Div", style=shape.xcross, location=location.abovebar, color=color.new(color.yellow, 0), size=size.small, text="DIV")

// ══════════════════════════════════════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════════════════════════════════════

if p_show_dash and barstate.islast
    var table dash = table.new(position.top_right, 2, 20, bgcolor=color.new(color.black, 15), border_width=1, border_color=color.gray, frame_width=2, frame_color=color.white)

    table.cell(dash, 0, 0, "BTC MOONSHOT", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.purple, 20), text_halign=text.align_center)
    table.merge_cells(dash, 0, 0, 1, 0)

    regime_color  = is_bull ? color.lime : is_bear ? color.red : color.yellow
    regime_bg     = is_bull ? color.new(color.green, 70) : is_bear ? color.new(color.red, 70) : color.new(color.yellow, 70)

    // 1 — Regime
    table.cell(dash, 0, 1, "BTC Regime",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 1, btc_regime,          text_color=regime_color, text_size=size.small, bgcolor=regime_bg, text_halign=text.align_right)

    // 2 — Price
    table.cell(dash, 0, 2, "BTC Price",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 2, "$" + str.tostring(close, "#,###"), text_color=btc_above_200 ? color.lime : color.red, text_size=size.small, text_halign=text.align_right)

    // 3 — RSI
    rsi_color = rsi_val >= p_rsi_lo and rsi_val <= p_rsi_hi ? color.lime : rsi_val < 30 ? color.aqua : color.red
    table.cell(dash, 0, 3, "RSI (" + str.tostring(p_rsi_len) + ")", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 3, str.tostring(rsi_val, "#.#"), text_color=rsi_color, text_size=size.small, text_halign=text.align_right)

    // 4 — Stochastic RSI
    stoch_color = stoch_oversold ? color.aqua : stoch_overbought ? color.orange : color.white
    stoch_text = str.tostring(stoch_k_raw, "#.#") + (stoch_oversold ? " OS" : stoch_overbought ? " OB" : "")
    table.cell(dash, 0, 4, "Stoch RSI",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 4, stoch_text,          text_color=stoch_color, text_size=size.small, text_halign=text.align_right)

    // 5 — MACD
    macd_color = macd_bullish and macd_positive ? color.lime : macd_bullish ? color.yellow : color.red
    macd_text = macd_bullish ? "BULL" : "BEAR"
    macd_text := macd_bearish_div ? macd_text + " DIV!" : macd_text
    table.cell(dash, 0, 5, "MACD",             text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 5, macd_text,           text_color=macd_color,  text_size=size.small, text_halign=text.align_right)

    // 6 — Parabolic SAR
    sar_color = sar_bullish ? color.lime : color.red
    table.cell(dash, 0, 6, "Parabolic SAR",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 6, sar_bullish ? "BULLISH" : "BEARISH", text_color=sar_color, text_size=size.small, text_halign=text.align_right)

    // 7 — Volume Ratio
    vol_color = vol_ratio > p_vol_mult ? color.lime : color.white
    table.cell(dash, 0, 7, "Vol Ratio",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 7, str.tostring(vol_ratio, "#.##") + "x", text_color=vol_color, text_size=size.small, text_halign=text.align_right)

    // 8 — Momentum
    mom_color = mom_pct > p_mom_thresh ? color.lime : color.red
    table.cell(dash, 0, 8, "Momentum " + str.tostring(p_mom_len) + "d", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 8, str.tostring(mom_pct, "#.#") + "%", text_color=mom_color, text_size=size.small, text_halign=text.align_right)

    // 9 — MA Status
    ma_text = above_200 ? "Above 200" : "Below 200"
    table.cell(dash, 0, 9, "MA Status",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 9, ma_text,            text_color=above_200 ? color.lime : color.red, text_size=size.small, text_halign=text.align_right)

    // 10 — Entry Signal
    sig_text  = all_entry ? "FIRE" : str.tostring(entry_score) + "/6"
    sig_color = all_entry ? color.lime : entry_score >= 4 ? color.yellow : color.red
    sig_bg    = all_entry ? color.new(color.green, 60) : color.new(color.black, 15)
    table.cell(dash, 0, 10, "Entry Signal",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 10, sig_text,           text_color=sig_color,   text_size=size.small, bgcolor=sig_bg, text_halign=text.align_right)

    // 11 — Confirmations
    conf_text = str.tostring(confirm_score) + "/3"
    table.cell(dash, 0, 11, "Confirms",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 11, conf_text,          text_color=confirm_score >= 2 ? color.lime : color.yellow, text_size=size.small, text_halign=text.align_right)

    // 12 — Cycle Phase
    cyc_color = cycle_phase == "MARKUP" ? color.lime : cycle_phase == "EUPHORIA" ? color.fuchsia : cycle_phase == "ACCUMULATION" ? color.aqua : color.red
    table.cell(dash, 0, 12, "Cycle Phase",     text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 12, cycle_phase,        text_color=cyc_color,   text_size=size.small, text_halign=text.align_right)

    // 13 — Entry Price
    entry_text = strategy.opentrades > 0 ? "$" + str.tostring(entry_px, "#,###") : "FLAT"
    table.cell(dash, 0, 13, "Entry Price",     text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 13, entry_text,         text_color=strategy.opentrades > 0 ? color.white : color.gray, text_size=size.small, text_halign=text.align_right)

    // 14 — Open P&L
    pnl_text  = strategy.opentrades > 0 ? str.tostring(current_pnl_pct, "#.#") + "%" : "—"
    pnl_color = current_pnl_pct > 0 ? color.lime : current_pnl_pct < 0 ? color.red : color.gray
    table.cell(dash, 0, 14, "Open P&L",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 14, pnl_text,           text_color=pnl_color,   text_size=size.small, text_halign=text.align_right)

    // 15 — Hold Bars
    hold_text  = strategy.opentrades > 0 ? str.tostring(bars_in_trade) + "/" + str.tostring(p_max_hold_bars) : "—"
    table.cell(dash, 0, 15, "Hold Bars",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 15, hold_text,          text_color=bars_in_trade > p_max_hold_bars * 0.8 ? color.orange : color.white, text_size=size.small, text_halign=text.align_right)

    // 16 — Trail Tier
    table.cell(dash, 0, 16, "Trail Tier",      text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 16, ladder_tier,        text_color=ladder_trail_active ? color.new(#FF00FF, 0) : color.gray, text_size=size.small, text_halign=text.align_right)

    // 17 — Trail Stop
    trail_text = ladder_trail_active ? "$" + str.tostring(ladder_trail_stop, "#,###") : "N/A"
    table.cell(dash, 0, 17, "Trail Stop",      text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 17, trail_text,         text_color=ladder_trail_triggered ? color.red : ladder_trail_active ? color.new(#FF00FF, 0) : color.gray, text_size=size.small, text_halign=text.align_right)

    // 18 — Position Peak
    hwm_text = strategy.opentrades > 0 ? "$" + str.tostring(hwm_val, "#,###") + " (+" + str.tostring(peak_gain_pct, "#") + "%)" : "—"
    table.cell(dash, 0, 18, "Pos Peak",         text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 18, hwm_text,           text_color=color.white, text_size=size.small, text_halign=text.align_right)

    // 19 — 200-Week MA
    ma200w_color = ma_200w_break ? color.red : color.lime
    table.cell(dash, 0, 19, "200W MA",          text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 19, (ma_200w_break ? "BELOW" : "ABOVE") + " $" + str.tostring(ma_200w, "#,###"), text_color=ma200w_color, text_size=size.small, text_halign=text.align_right)

// ══════════════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════════════

alertcondition(all_entry and strategy.opentrades == 0, title="BTC MOON BUY", message="BTC MOONSHOT ENTRY — All 6 conditions met. Load position.")
alertcondition(exit_death_cross, title="DEATH CROSS EXIT", message="BTC DEATH CROSS — EXIT ALL.")
alertcondition(partial_exit_warning, title="EMA50 LOSING EXIT", message="BTC below EMA 50 + volume spike + losing — full exit.")
alertcondition(exit_max_hold, title="MAX HOLD", message="BTC MOONSHOT max hold reached.")
alertcondition(exit_target, title="TARGET HIT", message="BTC MOONSHOT target reached — take profits.")
alertcondition(ladder_trail_triggered, title="LADDER TRAIL STOP", message="BTC MOONSHOT laddered trail stop triggered — EXIT.")
alertcondition(exit_200w, title="200W MA BREAK", message="BTC below 200-week MA — cycle support broken.")
alertcondition(macd_div_warning, title="MACD DIVERGENCE", message="BTC MACD bearish divergence — exhaustion warning.")
alertcondition(pt1_hit and not pt1_hit[1], title="PT1 3x", message="BTC MOONSHOT 3x — sold 25%")
alertcondition(pt2_hit and not pt2_hit[1], title="PT2 5x", message="BTC MOONSHOT 5x — sold 25%")
alertcondition(pt3_hit and not pt3_hit[1], title="PT3 10x", message="BTC MOONSHOT 10x — sold 25%")
alertcondition(pt4_hit and not pt4_hit[1], title="PT4 20x", message="BTC MOONSHOT 20x — sold final 25%")
