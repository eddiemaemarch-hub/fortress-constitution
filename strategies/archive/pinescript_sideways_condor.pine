//@version=6
// Rudy v2 - Sideways Mean Reversion (Iron Condor Proxy)
// Buys BB lows, sells BB highs in confirmed sideways regimes
// Simulates premium collection by scalping the range
// 10% position, tight targets, fast exits — profits from chop
// Apply to: SPY, QQQ, IWM, XLF, XLE, GLD, TLT
strategy("Rudy Sideways Reversion v2", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.5, slippage=5, pyramiding=0)

// --- Regime Detection ---
p_adx        = input.int(14, "ADX Lookback", group="Regime Detection")
p_adx_lim    = input.int(25, "ADX Ceiling (sideways < this)", group="Regime Detection")
p_rsi        = input.int(14, "RSI Lookback", group="Regime Detection")
p_rsi_lo     = input.int(30, "RSI Oversold (buy zone)", group="Regime Detection")
p_rsi_hi     = input.int(70, "RSI Overbought (sell zone)", group="Regime Detection")
p_bb         = input.int(20, "BB Lookback", group="Regime Detection")
p_bb_mult    = input.float(2.0, "BB Multiplier", group="Regime Detection")
p_bb_lim     = input.float(8.0, "BB Width Ceiling Pct", group="Regime Detection")
p_atr_len    = input.int(14, "ATR Length", group="Regime Detection")

// --- Mean Reversion Targets ---
p_target_pct = input.float(2.0, "Profit Target % (per scalp)", group="Reversion Targets") / 100
p_stop_pct   = input.float(3.0, "Stop Loss %", group="Reversion Targets") / 100
p_use_atr    = input.bool(true, "Use ATR-Based Stops", group="Reversion Targets")
p_atr_mult   = input.float(1.5, "ATR Stop Multiplier", group="Reversion Targets")
p_max_hold   = input.int(10, "Max Hold Bars", group="Reversion Targets")
p_use_short  = input.bool(true, "Enable Short (sell BB highs)", group="Reversion Targets")
p_hwm_trail_pct = input.float(30.0, "HWM Trail Floor %", group="Reversion Targets")
p_hwm_lookback  = input.int(252, "HWM Lookback Bars", group="Reversion Targets")

// Laddered Trailing Stop (tightens as gains grow)
p_lad_t1_gain  = input.float(15,   "Ladder Tier 1 at +%", group="Laddered Trail")
p_lad_t1_trail = input.float(15.0, "Ladder Tier 1 Trail %", group="Laddered Trail")
p_lad_t2_gain  = input.float(30,   "Ladder Tier 2 at +%", group="Laddered Trail")
p_lad_t2_trail = input.float(12.0, "Ladder Tier 2 Trail %", group="Laddered Trail")
p_lad_t3_gain  = input.float(50,   "Ladder Tier 3 at +%", group="Laddered Trail")
p_lad_t3_trail = input.float(10.0, "Ladder Tier 3 Trail %", group="Laddered Trail")

// --- Profit Taking ---
p_pt_tier1_pct  = input.float(30.0, "Tier 1 Profit %", group="Profit Taking")
p_pt_tier1_sell = input.float(50.0, "Tier 1 Sell %", group="Profit Taking")
p_pt_tier2_pct  = input.float(50.0, "Tier 2 Profit %", group="Profit Taking")
p_pt_tier2_sell = input.float(100.0, "Tier 2 Sell %", group="Profit Taking")

// --- Filters ---
p_use_vix    = input.bool(true, "VIX Filter", group="Filters")
p_vix_ticker = input.symbol("VIX", "VIX Symbol", group="Filters")
p_vix_max    = input.int(22, "VIX Max Level", group="Filters")
p_use_vol    = input.bool(true, "Volume Filter (want QUIET)", group="Filters")
p_vol_ma     = input.int(20, "Volume MA Period", group="Filters")
p_vol_mult   = input.float(1.0, "Volume Max Multiplier", group="Filters")
p_use_mtf    = input.bool(true, "Multi-Timeframe Sideways", group="Filters")
p_htf        = input.timeframe("D", "Higher Timeframe", group="Filters")
p_show_bg    = input.bool(true, "Color Background", group="Display")

// --- Core Calculations ---
[dpI, dmI, adxV] = ta.dmi(p_adx, p_adx)
rsiV = ta.rsi(close, p_rsi)
[bMid, bUp, bLo] = ta.bb(close, p_bb, p_bb_mult)
bWidth = (bUp - bLo) / bMid * 100
atr_val = ta.atr(p_atr_len)
hvProxy = ta.stdev(math.log(close / close[1]), 20) * math.sqrt(252) * 100

// --- Filters (non-repainting) ---
vix_val = request.security(p_vix_ticker, timeframe.period, close, barmerge.gaps_off, barmerge.lookahead_off)
vix_ok = vix_val < p_vix_max
vol_avg = ta.sma(volume, p_vol_ma)
vol_quiet = volume < vol_avg * p_vol_mult
[htf_dp, htf_dm, htf_adx] = request.security(syminfo.tickerid, p_htf, ta.dmi(14, 14), barmerge.gaps_off, barmerge.lookahead_off)
htf_sideways = htf_adx < p_adx_lim + 5

// --- Regime Detection ---
isFlat = adxV < p_adx_lim and bWidth < p_bb_lim
regimeOk = isFlat
regimeOk := regimeOk and (not p_use_vix or vix_ok)
regimeOk := regimeOk and (not p_use_vol or vol_quiet)
regimeOk := regimeOk and (not p_use_mtf or htf_sideways)

// --- Mean Reversion Signals ---
// Buy when price touches/crosses below lower BB + RSI oversold
buyDip = regimeOk and close <= bLo and rsiV < p_rsi_lo
// Short when price touches/crosses above upper BB + RSI overbought
sellRip = regimeOk and close >= bUp and rsiV > p_rsi_hi and p_use_short

// --- Position State ---
inLong = strategy.position_size > 0
inShort = strategy.position_size < 0
flat = strategy.position_size == 0
bars_in_trade = ta.barssince(flat[1] and not flat)
max_hold_exit = p_max_hold > 0 and (inLong or inShort) and bars_in_trade >= p_max_hold

// --- Profit Taking Tiers ---
var bool pt_tier1_done = false
var bool pt_tier2_done = false

if strategy.opentrades > 0
    entry_price_pt = strategy.opentrades.entry_price(0)
    gain_pct_pt = (close - entry_price_pt) / entry_price_pt * 100

    if gain_pct_pt >= p_pt_tier1_pct and not pt_tier1_done
        strategy.close(strategy.opentrades.entry_id(0), comment="PROFIT T1 +" + str.tostring(p_pt_tier1_pct, "#") + "%", qty_percent=p_pt_tier1_sell)
        pt_tier1_done := true

    if gain_pct_pt >= p_pt_tier2_pct and not pt_tier2_done
        strategy.close(strategy.opentrades.entry_id(0), comment="PROFIT T2 +" + str.tostring(p_pt_tier2_pct, "#") + "%", qty_percent=p_pt_tier2_sell)
        pt_tier2_done := true

// Reset on new trade
if strategy.opentrades == 0
    pt_tier1_done := false
    pt_tier2_done := false

// --- LONG ENTRY (buy the dip at lower BB) ---
if buyDip and flat
    strategy.entry("MR_Long", strategy.long)
    stopPrice = p_use_atr ? close - (atr_val * p_atr_mult) : close * (1 - p_stop_pct)
    strategy.exit("MR_Long_X", "MR_Long", stop=stopPrice, limit=bMid)

// --- SHORT ENTRY (sell the rip at upper BB) ---
if sellRip and flat
    strategy.entry("MR_Short", strategy.short)
    stopPrice = p_use_atr ? close + (atr_val * p_atr_mult) : close * (1 + p_stop_pct)
    strategy.exit("MR_Short_X", "MR_Short", stop=stopPrice, limit=bMid)

// --- Exit on regime break ---
if inLong and adxV > p_adx_lim + 8
    strategy.close("MR_Long", comment="Trend Break")
if inShort and adxV > p_adx_lim + 8
    strategy.close("MR_Short", comment="Trend Break")

// --- Exit on VIX spike ---
if p_use_vix and (inLong or inShort) and vix_val > p_vix_max * 1.3
    strategy.close_all(comment="VIX Spike")

// --- Max hold exit ---
if max_hold_exit
    strategy.close_all(comment="Max Hold")

// --- LADDERED Trailing Stop from HWM (Constitution v45.0) ---
var float pos_hwm = 0.0
if inLong
    pos_hwm := math.max(pos_hwm, high)
if flat
    pos_hwm := 0.0
hwm_val = pos_hwm > 0 ? pos_hwm : close
float entry_px_lad = strategy.position_avg_price
float gain_pct_lad = entry_px_lad > 0 ? (close - entry_px_lad) / entry_px_lad * 100 : 0
float peak_gain_pct = inLong and entry_px_lad > 0 ? (pos_hwm - entry_px_lad) / entry_px_lad * 100 : 0

var float active_trail = p_hwm_trail_pct
var string ladder_tier_str = "30% (floor)"

if inLong
    if peak_gain_pct >= p_lad_t3_gain
        active_trail := p_lad_t3_trail
        ladder_tier_str := str.tostring(p_lad_t3_gain,"#") + "%+ | " + str.tostring(p_lad_t3_trail,"#") + "% LOCK"
    else if peak_gain_pct >= p_lad_t2_gain
        active_trail := p_lad_t2_trail
        ladder_tier_str := str.tostring(p_lad_t2_gain,"#") + "%+ | " + str.tostring(p_lad_t2_trail,"#") + "% trail"
    else if peak_gain_pct >= p_lad_t1_gain
        active_trail := p_lad_t1_trail
        ladder_tier_str := str.tostring(p_lad_t1_gain,"#") + "%+ | " + str.tostring(p_lad_t1_trail,"#") + "% trail"
    else
        active_trail := p_hwm_trail_pct
        ladder_tier_str := str.tostring(p_hwm_trail_pct,"#") + "% (floor)"
else
    active_trail := p_hwm_trail_pct
    ladder_tier_str := str.tostring(p_hwm_trail_pct,"#") + "% (floor)"

hwm_trail_stop = hwm_val * (1 - active_trail / 100)
hwm_trail_triggered = inLong and close < hwm_trail_stop
if hwm_trail_triggered
    strategy.close("MR_Long", comment="Ladder Trail " + str.tostring(active_trail,"#") + "%")

// --- Take profit at mid-band if close crosses it ---
if inLong and close >= bMid
    strategy.close("MR_Long", comment="Mid-Band TP")
if inShort and close <= bMid
    strategy.close("MR_Short", comment="Mid-Band TP")

// --- Visuals ---
plot(bUp, "BB Upper", color.new(#9E9E9E, 30), 2)
plot(bLo, "BB Lower", color.new(#9E9E9E, 30), 2)
plot(bMid, "BB Mid", color.new(#FFD700, 50), 1, plot.style_circles)
fill(plot(bUp, display=display.none), plot(bLo, display=display.none), color=isFlat ? color.new(#4CAF50, 92) : color.new(#F44336, 96))
bgcolor(p_show_bg and isFlat ? color.new(#4CAF50, 95) : na)
plotshape(buyDip and flat, "Buy Dip", shape.triangleup, location.belowbar, color.new(#00E676, 0), size=size.small, text="BUY")
plotshape(sellRip and flat, "Sell Rip", shape.triangledown, location.abovebar, color.new(#F44336, 0), size=size.small, text="SHORT")
plotshape(max_hold_exit, "Max Hold", shape.xcross, location.abovebar, color.new(#FF9800, 0), size=size.tiny, text="MH")
plotshape(strategy.opentrades > 0 and pt_tier1_done and not pt_tier1_done[1], "PT1 Hit", shape.flag, location.abovebar, color.new(#00E676, 0), size=size.tiny, text="PT1")
plotshape(strategy.opentrades > 0 and pt_tier2_done and not pt_tier2_done[1], "PT2 Hit", shape.flag, location.abovebar, color.new(#00BCD4, 0), size=size.tiny, text="PT2")
plot(inLong and p_use_atr ? strategy.position_avg_price - (atr_val * p_atr_mult) : na, "Long Stop", color.new(color.red, 0), 1, plot.style_circles)
plot(inShort and p_use_atr ? strategy.position_avg_price + (atr_val * p_atr_mult) : na, "Short Stop", color.new(color.red, 0), 1, plot.style_circles)
plot(inLong ? hwm_trail_stop : na, "HWM Trail Stop", color.new(#FF00FF, 0), 2, plot.style_stepline)

// --- Dashboard ---
var table dash = table.new(position.top_right, 2, 19, bgcolor=color.new(#000000, 80), border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "REVERSION", text_color=color.new(#4CAF50, 0), text_size=size.normal)
    table.cell(dash, 1, 0, "Mean Rev", text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 1, "ADX", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(adxV, "#.#") + "/" + str.tostring(p_adx_lim), text_color=adxV < p_adx_lim ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 2, "RSI", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(rsiV, "#.#"), text_color=rsiV < p_rsi_lo ? color.lime : rsiV > p_rsi_hi ? color.red : color.yellow, text_size=size.small)
    table.cell(dash, 0, 3, "BB W", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(bWidth, "#.#") + "/" + str.tostring(p_bb_lim, "#.#") + "%", text_color=bWidth < p_bb_lim ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 4, "HV", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(hvProxy, "#.#") + "%", text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 5, "VIX", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, p_use_vix ? str.tostring(vix_val, "#.#") + "/" + str.tostring(p_vix_max) : "OFF", text_color=p_use_vix ? (vix_ok ? color.lime : color.red) : color.gray, text_size=size.small)
    table.cell(dash, 0, 6, "Volume", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, p_use_vol ? (vol_quiet ? "QUIET" : "ACTIVE") : "OFF", text_color=p_use_vol ? (vol_quiet ? color.lime : color.red) : color.gray, text_size=size.small)
    table.cell(dash, 0, 7, "HTF", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 7, p_use_mtf ? (htf_sideways ? "FLAT" : "TREND") : "OFF", text_color=p_use_mtf ? (htf_sideways ? color.lime : color.red) : color.gray, text_size=size.small)
    table.cell(dash, 0, 8, "Regime", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 8, isFlat ? "RANGE" : "TREND", text_color=isFlat ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 9, "Position", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 9, inLong ? "LONG" : inShort ? "SHORT" : "FLAT", text_color=inLong ? color.lime : inShort ? color.red : color.gray, text_size=size.small)
    table.cell(dash, 0, 10, "Signal", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 10, buyDip ? "BUY DIP" : sellRip ? "SELL RIP" : regimeOk ? "SCANNING" : "NO REGIME", text_color=buyDip ? color.lime : sellRip ? color.red : regimeOk ? color.yellow : color.gray, text_size=size.small)
    table.cell(dash, 0, 11, "Peak Gain", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 11, inLong ? str.tostring(peak_gain_pct, "+#.#") + "%" : "-", text_color=color.new(#FFD700, 0), text_size=size.small)
    table.cell(dash, 0, 12, "Pos Peak", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 12, inLong ? "$" + str.tostring(pos_hwm, "#.##") : "-", text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 13, "Trail Tier", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 13, ladder_tier_str, text_color=color.new(#FF00FF, 0), text_size=size.small)
    table.cell(dash, 0, 14, "Trail %", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 14, str.tostring(active_trail, "#") + "% from peak", text_color=color.new(#FF00FF, 0), text_size=size.small)
    table.cell(dash, 0, 15, "Trail Price", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 15, inLong ? str.tostring(hwm_trail_stop, "#.##") : "-", text_color=hwm_trail_triggered ? color.red : color.new(#FF00FF, 0), text_size=size.small)
    table.cell(dash, 0, 16, "Profit T1", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 16, str.tostring(p_pt_tier1_pct, "#") + "% → " + str.tostring(p_pt_tier1_sell, "#") + "% sell" + (pt_tier1_done ? " ✓" : ""), text_color=pt_tier1_done ? color.lime : color.gray, text_size=size.small)
    table.cell(dash, 0, 17, "Profit T2", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 17, str.tostring(p_pt_tier2_pct, "#") + "% → " + str.tostring(p_pt_tier2_sell, "#") + "% sell" + (pt_tier2_done ? " ✓" : ""), text_color=pt_tier2_done ? color.lime : color.gray, text_size=size.small)

alertcondition(buyDip and flat, "Buy Dip", "Sideways regime - BUY at lower BB")
alertcondition(sellRip and flat, "Sell Rip", "Sideways regime - SHORT at upper BB")
alertcondition((inLong or inShort) and adxV > p_adx_lim + 8, "Trend Break", "ADX breaking out - CLOSE position")
alertcondition(hwm_trail_triggered, "Ladder Trail", "Laddered trailing stop triggered — close long position")
alertcondition(strategy.opentrades > 0 and pt_tier1_done and not pt_tier1_done[1], "Profit T1", "Profit Tier 1 hit — sold 50% at +30%")
alertcondition(strategy.opentrades > 0 and pt_tier2_done and not pt_tier2_done[1], "Profit T2", "Profit Tier 2 hit — sold remaining at +50%")
