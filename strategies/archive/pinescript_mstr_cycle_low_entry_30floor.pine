//@version=6
// Rudy v2.2b — MSTR Cycle-Low LEAP Strategy (30% Floor Edition)
// SAME AS v2.2 Enhanced Edition with 250W dip+reclaim entry + 30% Initial Floor.
// USE THIS TO COMPARE P&L impact of the floor vs the no-floor version.
//
// CONFLUENCE ENTRY: 250W SMA dip+reclaim + Parabolic SAR bullish confirmed + RSI capitulation recovery
// All three must confirm = structural AND mathematical cycle low
// Trail: TWO-PHASE — 30% floor from entry (Phase 1), then laddered at +300%
//
// v2.2b FLOOR EDITION CHANGES (vs v2.2):
//   1. 30% Initial Floor: Hard stop at entry price -30% (before ladders kick in)
//   2. Ladders still activate at +300% (same as v2.2)
//   3. All other settings identical to v2.2 Enhanced
//
// QC Backtest v2.0 Results (Jan 2020 → Mar 2026, $100K initial):
//   Final Equity: $194,768 | Net Profit: +94.77% | Total Orders: 39
//   Win Rate: 29% | Avg Win: +33.54% | Avg Loss: -6.10% | P/L Ratio: 5.50x
//   Max Drawdown: 44.2% | Sharpe: 0.308
//   Big Winner: Sep 2024 entry @ $166 → PT1 Nov @ $334 (+505% LEAP), PT2 @ $385 (+655% LEAP)
//
// Apply to: MSTR 1M (monthly) chart for best P&L (29 trades, +3.7%). Weekly also works (74 trades, +2.57%). Use daily chart for precise entry timing.
strategy("MSTR Cycle-Low LEAP v2.2b (30% Floor)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=5, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=1.5, slippage=10, pyramiding=2)

// ══════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════

// --- MSTR Indicator Parameters ---
p_ema_entry     = input.int(21,  "Entry EMA",              group="MSTR Indicators")
p_ema_exit      = input.int(50,  "Exit EMA",               group="MSTR Indicators")
p_ema_200       = input.int(200, "200 EMA (Key Level)",     group="MSTR Indicators")
p_rsi_len       = input.int(14,  "RSI Length",              group="MSTR Indicators")
p_rsi_lo        = input.float(40.0, "RSI Floor",            group="MSTR Indicators")
p_rsi_hi        = input.float(75.0, "RSI Ceiling",          group="MSTR Indicators")
p_vol_avg_len   = input.int(20,  "Volume Avg Length",       group="MSTR Indicators")
p_vol_mult      = input.float(1.5, "Volume Surge Multiple", group="MSTR Indicators")
p_mom_len       = input.int(5,   "Momentum Lookback Bars",  group="MSTR Indicators")
p_mom_thresh    = input.float(3.0, "Momentum Threshold %",  group="MSTR Indicators")

// --- Parabolic SAR ---
p_sar_start     = input.float(0.02, "SAR Start",           group="Parabolic SAR")
p_sar_inc       = input.float(0.02, "SAR Increment",       group="Parabolic SAR")
p_sar_max       = input.float(0.20, "SAR Max",             group="Parabolic SAR")

// --- MACD ---
p_macd_fast     = input.int(12,  "MACD Fast",              group="MACD")
p_macd_slow     = input.int(26,  "MACD Slow",              group="MACD")
p_macd_sig      = input.int(9,   "MACD Signal",            group="MACD")

// --- Stochastic RSI ---
p_stoch_len     = input.int(14,  "Stoch RSI Length",        group="Stochastic RSI")
p_stoch_k       = input.int(3,   "Stoch K Smooth",          group="Stochastic RSI")
p_stoch_d       = input.int(3,   "Stoch D Smooth",          group="Stochastic RSI")

// --- MSTR 250-Week MA (PRIMARY ENTRY GATE) ---
// Rule: Price must be BELOW the 250W SMA = cycle low / beaten down territory
// Buy signal fires when MSTR is under this MA — catching the cycle bottom, not chasing highs.
// 2+ consecutive green candles below 250W = ENTRY ARMED (confirming a bottom bounce)
// Reset counter if price crosses ABOVE 250W (no longer in buy zone)
p_mstr_250w_len     = input.int(250,  "MSTR 250-Week SMA Length",      group="MSTR 250W Entry")
p_mstr_weekly_tf    = input.string("W", "MSTR Weekly Timeframe",       group="MSTR 250W Entry")
p_mstr_green_weeks  = input.int(2,    "Green Candles Below 250W to ARM", group="MSTR 250W Entry", minval=1, maxval=5)
p_use_mstr_250w     = input.bool(true, "Use MSTR 250W Below (vs BTC golden)", group="MSTR 250W Entry")

// --- Confluence Entry Gate ---
// Maximum conviction entry: 250W dip+reclaim + SAR flip bullish + RSI recovering from capitulation
// All three must confirm simultaneously = structural AND mathematical cycle low
p_use_confluence    = input.bool(true, "Require Confluence (250W Reclaim + SAR + RSI)", group="Confluence Entry")
p_rsi_capitulation  = input.float(30.0, "RSI Capitulation Threshold",          group="Confluence Entry")
p_rsi_recovery_bars = input.int(10, "RSI Recovery Lookback (bars)",            group="Confluence Entry", minval=1, maxval=50)
p_sar_confirm_bars  = input.int(3, "SAR Bullish Confirm (bars)",               group="Confluence Entry", minval=1, maxval=10)

// --- BTC Regime Parameters (kept for exits, dashboard, death cross) ---
p_btc_ticker    = input.symbol("BTCUSD",  "BTC Symbol",            group="BTC Regime")
p_btc_sma_slow  = input.int(200, "BTC Slow SMA Length",            group="BTC Regime")
p_btc_ema_fast  = input.int(50,  "BTC Fast EMA Length",            group="BTC Regime")
p_btc_sma_fast  = input.int(50,  "BTC Fast SMA (Death Cross)",     group="BTC Regime")

// --- MSTR/BTC Premium (mNAV) ---
p_btc_holdings  = input.float(738731, "MSTR BTC Holdings",         group="mNAV Premium")
p_shares_out    = input.float(335.0,  "MSTR Shares Out (millions)", group="mNAV Premium")
p_premium_high  = input.float(3.0,  "Premium Warning (euphoria)",   group="mNAV Premium")

// --- Cycle Timing ---
// NOTE: When using MSTR 250W dip+reclaim as primary entry gate, cycle timing is OPTIONAL.
// The 250W dip+reclaim itself encodes the cycle — MSTR only touches its 250W SMA
// at the start of macro bull moves (Mar-Apr 2023, Oct 2023, Oct 2024).
// Enable cycle filter ONLY if you want to further restrict entries to specific months.
p_use_cycle     = input.bool(false, "Enable Cycle Timing Filter",  group="Cycle")
p_entry_month_start = input.int(1,  "Entry Window Start Month",    group="Cycle", minval=1, maxval=12)
p_entry_month_end   = input.int(12, "Entry Window End Month",      group="Cycle", minval=1, maxval=12)
p_halving_year  = input.int(2024,   "Last BTC Halving Year",       group="Cycle")

// --- Risk / Hold Parameters ---
p_max_hold_bars = input.int(567, "Max Hold Bars (~27mo daily)",    group="Risk")
p_partial_exit_pct = input.float(50.0, "Partial Exit % on Warning", group="Risk")
p_target_mult   = input.float(20.0, "Target Return Multiple",      group="Risk")
p_entry_premium = input.float(8.0, "Target Entry Premium $/share", group="Risk")
p_num_contracts = input.int(125, "Number of Contracts",            group="Risk")

// --- Correlation ---
p_corr_len      = input.int(30, "BTC-MSTR Correlation Lookback",   group="Correlation")

// --- LEAP Leverage Multiplier (v2.1: Dynamic Realism) ---
// PineScript trades stock, not options. This multiplier converts stock gains to
// approximate LEAP gains for exit/PT calculations.
// v2.0 used static 5x — too conservative. Real far-OTM LEAPs in euphoria phases
// (2021, 2024-2025) did 10-30x on the same stock moves.
// Default 12x = realistic average for deep OTM calls during confirmed cycle moves.
// Run backtests at 8x (conservative) and 12x (realistic) to see range.
p_leap_mult     = input.float(8.0, "Dynamic LEAP Multiplier",    group="LEAP Simulation", minval=3, maxval=30, tooltip="Real euphoria LEAPs avg 10-30x. Use 8x conservative, 10x realistic, 15x aggressive.")

// --- Realism Mode (v2.1) ---
// Risk Capital: Only risk a fraction of total account on this lottery strategy.
// 25% default → $25K of a $100K account. Max drawdown drops from 44% to ~11% on full account.
p_risk_capital_pct = input.float(25.0, "Risk Capital (% of account)", group="Realism Mode", minval=5, maxval=100, tooltip="Only risk this % of total capital. 25% = sleep-at-night mode.")

// Panic Floor: Hard stop if position drops below this % in LEAP-equivalent terms.
// Even with no trail active (< +300%), this prevents catastrophic single-position loss.
// -25% LEAP terms at 12x mult = only -2% stock move. Adjust based on your mult.
p_panic_floor   = input.float(25.0, "Panic Floor (hard stop -% LEAP)", group="Realism Mode", minval=10, maxval=50, tooltip="Emergency exit if LEAP P&L drops below this. Prevents catastrophic loss.")
p_use_panic     = input.bool(true, "Enable Panic Floor", group="Realism Mode")

// Initial Floor: Hard stop at entry price minus X% (before ladders activate at +300%)
// Phase 1: Floor protects from catastrophic loss. Phase 2: Laddered trails take over.
p_initial_floor = input.float(30.0, "Initial Floor (% from entry)", group="Realism Mode", minval=5, maxval=50, tooltip="Hard stop at entry. If stock drops this % from entry price, exit. Protects before ladders activate at +300%.")
p_use_initial_floor = input.bool(true, "Enable Initial Floor", group="Realism Mode")

// --- Laddered Trailing Stop (Constitution v45.0) ---
// NO stop before +300% — MSTR volatility requires full room to breathe.
// Trail tightens with each partial sell as gains grow: 30% → 25% → 20% → 15% → 10%
p_lad_t1_gain   = input.float(300,  "Tier 1: Trail at +% (3x)",   group="Trail Stop")
p_lad_t1_trail  = input.float(30.0, "Tier 1: Trail %",            group="Trail Stop")
p_lad_t2_gain   = input.float(500,  "Tier 2: Trail at +% (5x)",   group="Trail Stop")
p_lad_t2_trail  = input.float(25.0, "Tier 2: Trail %",            group="Trail Stop")
p_lad_t3_gain   = input.float(1000, "Tier 3: Trail at +% (10x)",  group="Trail Stop")
p_lad_t3_trail  = input.float(20.0, "Tier 3: Trail %",            group="Trail Stop")
p_lad_t4_gain   = input.float(2000, "Tier 4: Trail at +% (20x)",  group="Trail Stop")
p_lad_t4_trail  = input.float(15.0, "Tier 4: Trail %",            group="Trail Stop")
p_lad_t5_gain   = input.float(5000, "Tier 5: Trail at +% (50x)",  group="Trail Stop")
p_lad_t5_trail  = input.float(10.0, "Tier 5: Trail % LOCK",       group="Trail Stop")

// --- Tiered Profit Taking (partial sells at each ladder level) ---
pt1_pct         = input.float(500,  "PT1 at +% (5x)",             group="Profit Taking")
pt1_sell        = input.float(25,   "PT1 Sell %",                  group="Profit Taking")
pt2_pct         = input.float(1000, "PT2 at +% (10x)",            group="Profit Taking")
pt2_sell        = input.float(25,   "PT2 Sell %",                  group="Profit Taking")
pt3_pct         = input.float(2000, "PT3 at +% (20x)",            group="Profit Taking")
pt3_sell        = input.float(25,   "PT3 Sell %",                  group="Profit Taking")
pt4_pct         = input.float(5000, "PT4 at +% (50x)",            group="Profit Taking")
pt4_sell        = input.float(25,   "PT4 Sell %",                  group="Profit Taking")

// --- Fallback Overrides (emergency exit triggers) ---
p_use_btc_200w  = input.bool(true, "BTC 200-Week MA Override",     group="Fallbacks")
p_btc_weekly_tf = input.string("W", "BTC Weekly Timeframe",        group="Fallbacks")
p_btc_200w_len  = input.int(200, "BTC 200-Week MA Length",         group="Fallbacks")
p_prem_compress = input.float(30.0, "Premium Compression % Exit",  group="Fallbacks")
p_use_prem_exit = input.bool(true, "Enable Premium Compression Exit", group="Fallbacks")

// --- Dashboard ---
p_show_dash     = input.bool(true, "Show Dashboard",               group="Display")
p_show_bg       = input.bool(true, "Show Regime Background",       group="Display")
p_show_sar      = input.bool(true, "Show Parabolic SAR",           group="Display")
p_show_premium  = input.bool(true, "Show mNAV Premium",            group="Display")

// --- Extra Filters (mandatory entry conditions, individually toggleable) ---
p_use_btc_above_200w  = input.bool(true,  "Require BTC Above 200W MA",       group="Extra Filters")
p_stoch_entry_thresh  = input.float(30.0, "Stoch RSI Entry Threshold",       group="Extra Filters", minval=5, maxval=50)
p_use_stoch_entry     = input.bool(true,  "Require Stoch RSI Oversold",      group="Extra Filters")
p_use_premium_expand  = input.bool(true,  "Require Premium Expanding",       group="Extra Filters")
p_use_no_macd_div     = input.bool(true,  "Require No MACD Bearish Div",     group="Extra Filters")
p_entry_max_premium   = input.float(1.5,  "Max Premium to Enter",            group="Extra Filters", minval=0.5, maxval=5.0)
p_use_premium_cap     = input.bool(true,  "Enable Premium Cap on Entry",     group="Extra Filters")

// --- Scale-In ---
p_use_scale_in    = input.bool(true,  "Scale In (50/50 split)",              group="Scale-In")
p_scale_in_pct    = input.float(50.0, "First Entry % of Risk Capital",       group="Scale-In", minval=10, maxval=100)

// --- Exit Enhancements ---
p_euphoria_premium_sell = input.float(3.5, "Euphoria Premium Sell Threshold", group="Exit Enhancements", minval=1.5, maxval=10.0)
p_use_euphoria_sell     = input.bool(true, "Enable Euphoria Premium Sell",    group="Exit Enhancements")

// --- Bonus ---
p_use_hybrid_entry    = input.bool(false, "Hybrid: Also allow entry on EMA200 crossover", group="Bonus")
p_use_halving_filter  = input.bool(false, "Only enter in halving year +0/+1",             group="Bonus")

// --- Sizing Calculator ---
p_total_capital       = input.float(130000, "Total LEAP Capital $",          group="Sizing Calculator")
p_avg_contract_cost   = input.float(1.0,    "Avg Contract Cost % of Spot",   group="Sizing Calculator", minval=0.1, maxval=10.0)

// ══════════════════════════════════════════════════════════════════════
// BTC DATA & REGIME
// ══════════════════════════════════════════════════════════════════════

btc_close     = request.security(p_btc_ticker, timeframe.period, close,           barmerge.gaps_off, barmerge.lookahead_off)
btc_sma_slow  = request.security(p_btc_ticker, timeframe.period, ta.sma(close, p_btc_sma_slow), barmerge.gaps_off, barmerge.lookahead_off)
btc_ema_fast  = request.security(p_btc_ticker, timeframe.period, ta.ema(close, p_btc_ema_fast), barmerge.gaps_off, barmerge.lookahead_off)
btc_sma_fast  = request.security(p_btc_ticker, timeframe.period, ta.sma(close, p_btc_sma_fast), barmerge.gaps_off, barmerge.lookahead_off)

btc_above_200  = btc_close > btc_sma_slow
btc_golden     = btc_ema_fast > btc_sma_slow
btc_death_cross = ta.crossunder(btc_sma_fast, btc_sma_slow)

// BTC 200-Week MA — ultimate cycle support. Break below = bear market confirmed.
btc_200w_ma = request.security(p_btc_ticker, p_btc_weekly_tf, ta.sma(close, p_btc_200w_len), barmerge.gaps_off, barmerge.lookahead_off)
btc_below_200w = btc_close < btc_200w_ma
btc_200w_break = p_use_btc_200w and btc_below_200w

// Regime classification
var string btc_regime = "NEUTRAL"
if btc_above_200 and btc_golden
    btc_regime := "BULL"
else if not btc_above_200 and not btc_golden
    btc_regime := "BEAR"
else
    btc_regime := "NEUTRAL"

is_bull = btc_regime == "BULL"
is_bear = btc_regime == "BEAR"

// ══════════════════════════════════════════════════════════════════════
// MSTR 250-WEEK SMA — PRIMARY ENTRY REGIME (DIP BELOW → RECLAIM)
// ══════════════════════════════════════════════════════════════════════
// CYCLE LOW THESIS: Buy when MSTR touches/dips BELOW the 250W SMA then RECLAIMS it.
// The dip below = cycle-low capitulation (maximum fear, cheapest LEAPs).
// The reclaim = structural recovery confirmed (not catching a falling knife).
//
// Entry logic:
// 1. MSTR must have been BELOW the 250W SMA at some point (dip/touch confirmed)
// 2. MSTR weekly close then crosses back ABOVE the 250W SMA (reclaim)
// 3. Count consecutive green candles ABOVE the 250W after reclaim
// 4. Entry ARMED when count reaches threshold (default: 2 green candles above)
// 5. If price drops back BELOW 250W SMA → counter resets (false reclaim)
// 6. Dip flag resets after a sustained run above (next cycle)
//
// This catches the exact inflection: beaten down → recovery confirmed.
// Not buying the dip itself (knife catch) — buying the PROVEN reclaim.

// MSTR weekly data (applied to MSTR's own chart, no external request needed)
mstr_weekly_close = request.security(syminfo.tickerid, p_mstr_weekly_tf, close, barmerge.gaps_off, barmerge.lookahead_off)
mstr_weekly_open  = request.security(syminfo.tickerid, p_mstr_weekly_tf, open,  barmerge.gaps_off, barmerge.lookahead_off)
mstr_250w_sma     = request.security(syminfo.tickerid, p_mstr_weekly_tf, ta.sma(close, p_mstr_250w_len), barmerge.gaps_off, barmerge.lookahead_off)

// Weekly candle qualifiers
mstr_below_250w    = mstr_weekly_close < mstr_250w_sma
mstr_above_250w    = mstr_weekly_close > mstr_250w_sma
mstr_green_candle  = mstr_weekly_close > mstr_weekly_open

// Phase 1: Track if price has dipped below/touched the 250W SMA (cycle low confirmed)
// This flag persists until entry fires or a sustained bull run resets it.
var bool mstr_dipped_below_250w = false
var bool already_entered_this_cycle = false
if mstr_below_250w
    mstr_dipped_below_250w := true

// Phase 2: After dip confirmed, count consecutive green candles ABOVE 250W (reclaim)
// Resets if price drops back below (false reclaim / re-test)
// Must work on ANY chart timeframe (daily, weekly, monthly).
var int mstr_green_count = 0

bool is_monthly_or_higher = timeframe.ismonthly
bool new_period = is_monthly_or_higher ? true : (ta.change(time(p_mstr_weekly_tf)) != 0)

if new_period
    if mstr_dipped_below_250w and mstr_above_250w and mstr_green_candle
        mstr_green_count := mstr_green_count + 1
    else if mstr_below_250w
        mstr_green_count := 0
    // Red candle above 250W after dip: don't increment, don't reset — pause

// Entry ARMED: dip happened + now reclaimed with consecutive green candles above 250W
mstr_250w_armed = mstr_dipped_below_250w and mstr_green_count >= p_mstr_green_weeks

// Fresh cross detection (for alerts)
mstr_250w_cross_below = mstr_below_250w and not mstr_below_250w[1]  // entering dip zone
mstr_250w_cross_above = mstr_above_250w and not mstr_above_250w[1]  // reclaiming!

// Combined regime gate: use MSTR 250W dip+reclaim if enabled, else fall back to BTC golden cross
// Price must be above 250W SMA (reclaimed) — confirmed by green candle count.
// Works on any timeframe: daily close, weekly close, or monthly close.
// When confluence mode is ON: requires 250W armed + SAR confirmed + RSI recovery
// When confluence mode is OFF: just 250W armed + reclaim confirmed
mstr_reclaim_confirmed = mstr_dipped_below_250w and close > mstr_250w_sma
// NOTE: confluence_confirmed is defined AFTER SAR/RSI are calculated (further down in code).
// PineScript evaluates top-to-bottom, so we use a forward reference workaround:
// regime_entry_ok is reassigned after confluence_confirmed is available (see CONFLUENCE REASSIGNMENT below).
regime_entry_ok = p_use_mstr_250w ? (mstr_250w_armed and mstr_reclaim_confirmed) : is_bull

// ══════════════════════════════════════════════════════════════════════
// MSTR/BTC PREMIUM (mNAV) — Sentiment Euphoria Gauge
// ══════════════════════════════════════════════════════════════════════
// Tracks ratio of MSTR market cap to its BTC holdings value.
// Premium explodes (2-5x+ NAV) in bull runs = rocket igniting.
// Low premium = undervaluation/mean-reversion setup.
// Surging premium confirms hold calls longer / scale partial profits.

btc_value_per_share = (btc_close * p_btc_holdings) / (p_shares_out * 1000000)
mstr_premium = btc_value_per_share > 0 ? close / btc_value_per_share : 1.0
premium_expanding = mstr_premium > mstr_premium[20]
premium_euphoria = mstr_premium > p_premium_high

// Premium compression: if mNAV premium drops >30% from its 20-bar high = thesis weakening
var float premium_hwm = 0.0
if strategy.opentrades > 0
    premium_hwm := math.max(premium_hwm, mstr_premium)
if strategy.opentrades == 0
    premium_hwm := 0.0
premium_drop_pct = premium_hwm > 0 ? (premium_hwm - mstr_premium) / premium_hwm * 100 : 0
premium_compressed = p_use_prem_exit and premium_drop_pct >= p_prem_compress and strategy.opentrades > 0

// ══════════════════════════════════════════════════════════════════════
// MSTR CALCULATIONS — Core Indicators
// ══════════════════════════════════════════════════════════════════════

ema_entry   = ta.ema(close, p_ema_entry)
ema_exit    = ta.ema(close, p_ema_exit)
ema_200     = ta.ema(close, p_ema_200)
rsi_val     = ta.rsi(close, p_rsi_len)
vol_avg     = ta.sma(volume, p_vol_avg_len)
vol_ratio   = volume / vol_avg
mom_pct     = (close - close[p_mom_len]) / close[p_mom_len] * 100

// Golden Cross (50-day > 200-day) — bull continuation
mstr_golden_cross = ta.crossover(ema_exit, ema_200)
mstr_above_200 = close > ema_200

// ══════════════════════════════════════════════════════════════════════
// PARABOLIC SAR — Trend Filter
// ══════════════════════════════════════════════════════════════════════
// Dots flipping below price confirms bullish regime shift.
// Dots above = bearish pressure. Aligns with entry timing.

sar_val = ta.sar(p_sar_start, p_sar_inc, p_sar_max)
sar_bullish = close > sar_val
sar_flip_bull = sar_bullish and not sar_bullish[1]
sar_flip_bear = not sar_bullish and sar_bullish[1]

// ══════════════════════════════════════════════════════════════════════
// CONFLUENCE DETECTION — Cycle Low Confirmation
// ══════════════════════════════════════════════════════════════════════
// 1. RSI CAPITULATION RECOVERY: Persistent flag — tracks that RSI hit capitulation
//    at some point during this cycle low. Resets after sustained run above 250W SMA.
//    This way the timing doesn't need to be simultaneous — RSI capitulates at the
//    bottom, MSTR reclaims 250W weeks later, and the flag remembers the capitulation.
//    NOTE: If chart doesn't load back to 2022 bear market, RSI may never hit <30.
//    In that case, the flag stays false and no entries fire. Load more history
//    or reduce p_rsi_capitulation threshold.
// On monthly charts, RSI is too smooth to hit <30. Pull weekly RSI as fallback.
float weekly_rsi = timeframe.ismonthly ? request.security(syminfo.tickerid, "W", ta.rsi(close, p_rsi_len), barmerge.gaps_off, barmerge.lookahead_off) : rsi_val
// Use whichever RSI is lower (weekly captures intra-month capitulation that monthly smooths out)
float capit_rsi = math.min(rsi_val, weekly_rsi)

var bool rsi_hit_capitulation = false
if capit_rsi < p_rsi_capitulation
    rsi_hit_capitulation := true
// Reset the capitulation flag after price has been above 250W AND green count is well past entry
// (i.e., the dip+reclaim cycle is complete and a new bull run is established)
// Don't reset during the reclaim itself — the flag needs to survive through entry!
if mstr_above_250w and mstr_green_count > p_mstr_green_weeks + 10
    rsi_hit_capitulation := false  // well into bull run, reset for next cycle
    mstr_dipped_below_250w := false  // also reset dip flag for next cycle
    already_entered_this_cycle := false  // reset for next cycle
rsi_recovering = rsi_hit_capitulation and rsi_val > p_rsi_capitulation

// DEBUG: Force capitulation flag if chart history is too short to capture the 2022 bear
// This ensures entries fire even on shorter chart windows where RSI<30 isn't visible.
// MSTR RSI hit <25 in June 2022, Jan 2023 — if chart starts after that, flag stays false.
// On monthly charts, this is auto-enabled since monthly RSI rarely hits <30.
p_force_capit = input.bool(false, "Force RSI Capitulation Flag (short chart fix)", group="Confluence Entry")
if p_force_capit or (timeframe.ismonthly and not rsi_hit_capitulation and mstr_below_250w)
    rsi_hit_capitulation := true

// 2. SAR BULLISH CONFIRMED: SAR dots below price for N consecutive bars
//    Not just a single flip — sustained bullish SAR = trend confirmed
var int sar_bull_count = 0
if sar_bullish
    sar_bull_count := sar_bull_count + 1
else
    sar_bull_count := 0
sar_confirmed = sar_bull_count >= p_sar_confirm_bars

// 3. CONFLUENCE GATE: All three signals converging
//    250W dip+reclaim armed + SAR confirmed (trend turning) + RSI recovery from capitulation
//    RSI flag persists from cycle low — doesn't need to be simultaneous
confluence_confirmed = mstr_250w_armed and sar_confirmed and rsi_recovering

// CONFLUENCE REASSIGNMENT: Now that confluence_confirmed is calculated, override regime_entry_ok
// Confluence ON: all 3 signals + price reclaimed above 250W SMA
// Confluence OFF: just 250W armed + reclaim confirmed (original behavior)
// Standard regime entry (250W dip+reclaim or BTC golden)
bool standard_regime = p_use_mstr_250w ? (p_use_confluence ? (confluence_confirmed and mstr_reclaim_confirmed) : (mstr_250w_armed and mstr_reclaim_confirmed)) : is_bull
// Hybrid entry: also allow entry on EMA200 crossover (without requiring 250W dip+reclaim)
bool hybrid_ema200_entry = p_use_hybrid_entry and ta.crossover(close, ema_200)
regime_entry_ok := standard_regime or hybrid_ema200_entry

// ══════════════════════════════════════════════════════════════════════
// MACD — Momentum & Divergences
// ══════════════════════════════════════════════════════════════════════
// Bullish MACD cross confirms momentum. Bearish divergence warns of
// exhaustion during the run (partial profit-taking signal).

[macd_line, macd_signal, macd_hist] = ta.macd(close, p_macd_fast, p_macd_slow, p_macd_sig)
macd_bull_cross = ta.crossover(macd_line, macd_signal)
macd_bear_cross = ta.crossunder(macd_line, macd_signal)
macd_bullish = macd_line > macd_signal
macd_positive = macd_line > 0

// MACD divergence detection (price higher high, MACD lower high = bearish divergence)
price_hh = high > ta.highest(high, 20)[1]
macd_lh = macd_line < ta.highest(macd_line, 20)[1]
macd_bearish_div = price_hh and macd_lh and strategy.opentrades > 0

// ══════════════════════════════════════════════════════════════════════
// STOCHASTIC RSI — Oversold Bounce Detection
// ══════════════════════════════════════════════════════════════════════
// Oversold signals (<20) in pullbacks during a bull run = reload zones.
// Overbought (>80) doesn't kill thesis but warns of short-term pause.

stoch_rsi_raw = ta.rsi(close, p_stoch_len)
stoch_k_raw = ta.sma(ta.stoch(stoch_rsi_raw, stoch_rsi_raw, stoch_rsi_raw, p_stoch_len), p_stoch_k)
stoch_d_raw = ta.sma(stoch_k_raw, p_stoch_d)
stoch_oversold = stoch_k_raw < 20
stoch_overbought = stoch_k_raw > 80

// ══════════════════════════════════════════════════════════════════════
// BTC-MSTR CORRELATION & IMPLIED LEVERAGE
// ══════════════════════════════════════════════════════════════════════

mstr_returns = (close - close[1]) / close[1]
btc_returns  = (btc_close - btc_close[1]) / btc_close[1]
beta_corr    = ta.correlation(mstr_returns, btc_returns, p_corr_len)

// Implied leverage: ratio of MSTR vol to BTC vol (rolling)
mstr_std     = ta.stdev(mstr_returns, p_corr_len)
btc_std      = ta.stdev(btc_returns, p_corr_len)
implied_lev  = btc_std > 0 ? mstr_std / btc_std : 1.0

// ══════════════════════════════════════════════════════════════════════
// POWER LAW / ADOPTION MODEL — Long-Term Target Zone
// ══════════════════════════════════════════════════════════════════════
// Simple power law projection for MSTR based on BTC adoption curve.
// Not predictive — used to set mental "moon" levels for the run.
// If BTC hits $200k, MSTR at 3.63x beta could reach $500-$2500+.

btc_moon_150k = 150000.0
btc_moon_200k = 200000.0
btc_moon_250k = 250000.0
mstr_target_150k = btc_value_per_share * (btc_moon_150k / btc_close) * implied_lev
mstr_target_200k = btc_value_per_share * (btc_moon_200k / btc_close) * implied_lev
mstr_target_250k = btc_value_per_share * (btc_moon_250k / btc_close) * implied_lev

// ══════════════════════════════════════════════════════════════════════
// CYCLE PHASE
// ══════════════════════════════════════════════════════════════════════

years_since_halving = year - p_halving_year
cycle_year = years_since_halving % 4  // 0 = halving year, 1 = post-halving, etc.

var string cycle_phase = "ACCUMULATION"
if cycle_year == 0
    cycle_phase := "ACCUMULATION"
else if cycle_year == 1
    cycle_phase := "MARKUP"
else if cycle_year == 2
    cycle_phase := "EUPHORIA"
else
    cycle_phase := "DISTRIBUTION"

in_entry_window = p_use_cycle ? (month >= p_entry_month_start and month <= p_entry_month_end) : true
is_post_halving = cycle_year == 0 or cycle_year == 1  // best 2 years of the cycle

// ══════════════════════════════════════════════════════════════════════
// ENTRY CONDITIONS (6 core + 4 extra filters + supporting confirmations)
// ══════════════════════════════════════════════════════════════════════

// 6 core conditions
// cond_regime uses MSTR 250W below (buy in the cycle-low zone when beaten down)
// BTC golden cross demoted to supporting confirmation — still tracked for exits and dashboard
cond_price_above_ema = close > ema_entry
cond_volume_surge    = vol_ratio > p_vol_mult
cond_rsi_zone        = rsi_val >= p_rsi_lo and rsi_val <= p_rsi_hi
cond_momentum        = mom_pct > p_mom_thresh
cond_regime          = regime_entry_ok  // MSTR below 250W (primary) or BTC golden (fallback)
// When MSTR 250W below is primary, being in the buy zone IS the cycle timing — self-filtering.
// Cycle filter only applies when using BTC golden cross as primary (legacy mode).
cond_cycle           = p_use_mstr_250w ? true : (p_use_cycle ? (in_entry_window and is_post_halving) : true)

// 4 extra confluence filters (each individually toggleable)
cond_btc_above_200w    = p_use_btc_above_200w ? not btc_below_200w : true
cond_stoch_oversold    = p_use_stoch_entry ? stoch_k_raw < p_stoch_entry_thresh : true
cond_premium_expanding = p_use_premium_expand ? premium_expanding : true
cond_no_macd_div       = p_use_no_macd_div ? not macd_bearish_div : true
cond_premium_cap       = p_use_premium_cap ? mstr_premium <= p_entry_max_premium : true

// Max 1 entry per cycle — prevent re-entering the same dip+reclaim cycle
cond_not_already_entered = not already_entered_this_cycle

// Halving-year filter (bonus)
cond_halving = p_use_halving_filter ? is_post_halving : true

all_entry = cond_price_above_ema and cond_volume_surge and cond_rsi_zone and cond_momentum and cond_regime and cond_cycle and cond_btc_above_200w and cond_stoch_oversold and cond_premium_expanding and cond_no_macd_div and cond_premium_cap and cond_not_already_entered and cond_halving

// Supporting confirmations (not required, but strengthen conviction)
// BTC golden cross moved here — it confirms but doesn't block entry
confirm_sar = sar_bullish
confirm_macd = macd_bullish
confirm_golden = mstr_above_200
confirm_premium = not premium_euphoria  // don't enter at peak euphoria
confirm_btc_bull = is_bull              // BTC golden cross (was primary, now confirmation)

// Count how many conditions are met (for dashboard) — now /10 with extra filters
entry_score = (cond_price_above_ema ? 1 : 0) + (cond_volume_surge ? 1 : 0) + (cond_rsi_zone ? 1 : 0) + (cond_momentum ? 1 : 0) + (cond_regime ? 1 : 0) + (cond_cycle ? 1 : 0) + (cond_btc_above_200w ? 1 : 0) + (cond_stoch_oversold ? 1 : 0) + (cond_premium_expanding ? 1 : 0) + (cond_no_macd_div ? 1 : 0)

// Confirmation score (supporting, not required) — BTC golden cross now here (5 total)
confirm_score = (confirm_sar ? 1 : 0) + (confirm_macd ? 1 : 0) + (confirm_golden ? 1 : 0) + (confirm_premium ? 1 : 0) + (confirm_btc_bull ? 1 : 0)

// ══════════════════════════════════════════════════════════════════════
// EXIT CONDITIONS
// ══════════════════════════════════════════════════════════════════════

// P&L calculation (must be before exit conditions that reference it)
// LEAP simulation: multiply stock gain by LEAP leverage to approximate options P&L
// e.g., +100% stock gain × 5x multiplier = +500% LEAP gain → triggers PT1 at 5x
entry_px        = strategy.opentrades > 0 ? strategy.opentrades.entry_price(strategy.opentrades - 1) : na
stock_pnl_pct   = strategy.opentrades > 0 ? (close - entry_px) / entry_px * 100 : 0.0

// v2.1: Dynamic LEAP multiplier with premium boost
// When mNAV premium expands (>2x), LEAP gains amplify due to delta/gamma/vega expansion
// Base mult × premium boost = realistic euphoria-phase returns
premium_boost   = mstr_premium > 2.0 ? 1.5 : mstr_premium > 1.5 ? 1.2 : 1.0
dynamic_leap_mult = p_leap_mult * premium_boost
current_pnl_pct = stock_pnl_pct * dynamic_leap_mult

// Death cross on BTC = hard exit (the thesis is dead)
exit_death_cross = btc_death_cross

// FALLBACK 1: BTC below 200-week MA = cycle support broken, force tighter trail or exit
// If in profit: force trail to 15% regardless of tier. If losing: full exit.
exit_btc_200w = btc_200w_break and strategy.opentrades > 0

// FALLBACK 2: Premium compression >30% from peak = MSTR thesis weakening
// Accelerate partial sell (50%) to lock remaining gains
exit_premium_compress = premium_compressed

// MSTR drops below EMA 50 with volume spike AND position is losing = full exit
partial_exit_warning = close < ema_exit and vol_ratio > p_vol_mult and current_pnl_pct < 0

// Max hold exceeded
bars_in_trade  = strategy.opentrades > 0 ? bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1) : 0
exit_max_hold  = bars_in_trade >= p_max_hold_bars and strategy.opentrades > 0

// Target reached (20x LEAP-equivalent)
exit_target    = strategy.opentrades > 0 and current_pnl_pct >= (p_target_mult - 1) * 100

// Premium peak warning — premium at euphoria levels during a run
premium_peak_warning = premium_euphoria and strategy.opentrades > 0 and current_pnl_pct > 500

// MACD bearish divergence during run — early exhaustion signal
macd_div_warning = macd_bearish_div and current_pnl_pct > 200

// ══════════════════════════════════════════════════════════════════════
// LADDERED TRAILING STOP (Constitution v45.0)
// ══════════════════════════════════════════════════════════════════════
// NO trail until +300% — deep OTM LEAPs need full exposure during early acceleration.
// MSTR routinely swings 30-40% in bull runs — any floor tighter than that = death by stops.
// Trail TIGHTENS at each profit-taking level: 30% → 25% → 20% → 15% → 10%.
// Tracks position peak (not market HWM) — locks profits on the way UP.
// Once a tier is reached (based on peak gain), it NEVER loosens back.

var float pos_hwm = 0.0
if strategy.opentrades > 0
    pos_hwm := math.max(pos_hwm, high)
if strategy.opentrades == 0
    pos_hwm := 0.0
hwm_val = pos_hwm > 0 ? pos_hwm : close
gain_pct = current_pnl_pct

// Peak gain from position high water mark (not current price) — with LEAP leverage
float peak_gain_pct = strategy.opentrades > 0 and entry_px > 0 ? (pos_hwm - entry_px) / entry_px * 100 * dynamic_leap_mult : 0.0

// Determine current tier and trail percentage based on PEAK gain
// Tiers only ratchet UP — once +500% peak is reached, trail stays at 25% even if price drops
var float ladder_trail_pct = 0.0
var string ladder_tier = "NONE (lottery < +300%)"
if peak_gain_pct >= p_lad_t5_gain
    ladder_trail_pct := p_lad_t5_trail
    ladder_tier := "50x+ | " + str.tostring(p_lad_t5_trail,"#") + "% LOCK"
else if peak_gain_pct >= p_lad_t4_gain
    ladder_trail_pct := p_lad_t4_trail
    ladder_tier := "20x+ | " + str.tostring(p_lad_t4_trail,"#") + "% trail"
else if peak_gain_pct >= p_lad_t3_gain
    ladder_trail_pct := p_lad_t3_trail
    ladder_tier := "10x+ | " + str.tostring(p_lad_t3_trail,"#") + "% trail"
else if peak_gain_pct >= p_lad_t2_gain
    ladder_trail_pct := p_lad_t2_trail
    ladder_tier := "5x+ | " + str.tostring(p_lad_t2_trail,"#") + "% trail"
else if peak_gain_pct >= p_lad_t1_gain
    ladder_trail_pct := p_lad_t1_trail
    ladder_tier := "3x+ | " + str.tostring(p_lad_t1_trail,"#") + "% trail"
else
    ladder_trail_pct := 0.0
    ladder_tier := p_use_initial_floor ? "FLOOR " + str.tostring(p_initial_floor, "#") + "%" : "NONE (lottery < +300%)"

// Phase 1 (Entry → +300%): INITIAL FLOOR — hard stop at entry price minus 30%.
// Before ladders kick in, this floor prevents catastrophic drawdown.
// Hard stop at entry_px * (1 - initial_floor%). Not a trailing stop — just a floor.
float initial_floor_price = entry_px > 0 ? entry_px * (1 - p_initial_floor / 100) : na
bool initial_floor_active = p_use_initial_floor and strategy.opentrades > 0 and peak_gain_pct < p_lad_t1_gain
bool initial_floor_triggered = initial_floor_active and close < initial_floor_price

// Trail activates at +300% (3x) — no stop before that
ladder_trail_active = strategy.opentrades > 0 and peak_gain_pct >= p_lad_t1_gain
ladder_trail_stop = ladder_trail_active ? pos_hwm * (1 - ladder_trail_pct / 100) : na
ladder_trail_triggered = ladder_trail_active and close < ladder_trail_stop

// ══════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ══════════════════════════════════════════════════════════════════════

// Tiered profit taking — partial sells at each ladder level
var bool pt1_hit = false
var bool pt2_hit = false
var bool pt3_hit = false
var bool pt4_hit = false

if strategy.opentrades > 0
    if gain_pct >= pt1_pct and not pt1_hit
        strategy.close("MOONSHOT", comment="PT1 5x +" + str.tostring(pt1_pct,"#") + "%", qty_percent=pt1_sell)
        pt1_hit := true
    if gain_pct >= pt2_pct and not pt2_hit
        strategy.close("MOONSHOT", comment="PT2 10x +" + str.tostring(pt2_pct,"#") + "%", qty_percent=pt2_sell)
        pt2_hit := true
    if gain_pct >= pt3_pct and not pt3_hit
        strategy.close("MOONSHOT", comment="PT3 20x +" + str.tostring(pt3_pct,"#") + "%", qty_percent=pt3_sell)
        pt3_hit := true
    if gain_pct >= pt4_pct and not pt4_hit
        strategy.close("MOONSHOT", comment="PT4 50x +" + str.tostring(pt4_pct,"#") + "%", qty_percent=pt4_sell)
        pt4_hit := true

if strategy.opentrades == 0
    pt1_hit := false
    pt2_hit := false
    pt3_hit := false
    pt4_hit := false

// ENTRY: Confluence gate — 250W SMA dip+reclaim + SAR bullish confirmed + RSI capitulation recovery
// All three must fire simultaneously = structural AND mathematical cycle low
// After exit, green_count must reset (red week) then rebuild before re-entry is allowed.
// v2.1: Risk capital sizing — only risk p_risk_capital_pct of total equity
// v2.2: Scale-in support — split entry into two tranches
risk_qty_pct = p_risk_capital_pct / 100 * 100  // % of equity to deploy (e.g., 25% risk → 25% position)
entry_comment = p_use_confluence ? "CONFLUENCE ENTRY (BELOW 250W+SAR+RSI)" : "BELOW 250W ENTRY"

var int entry_count_this_cycle = 0

// Reset entry count after full exit
if strategy.opentrades == 0 and entry_count_this_cycle > 0
    entry_count_this_cycle := 0

// First entry
float first_entry_pct = p_use_scale_in ? p_scale_in_pct / 100 : 1.0
if all_entry and strategy.opentrades == 0
    strategy.entry("MOONSHOT", strategy.long, qty=strategy.equity * (p_risk_capital_pct / 100) * first_entry_pct / close, comment=entry_comment + (p_use_scale_in ? " [1/2]" : ""))
    already_entered_this_cycle := true
    entry_count_this_cycle := 1

// Scale-in: second entry on NEXT green candle after first entry (if still in position and conditions still met)
// Note: uses core entry conditions WITHOUT cond_not_already_entered (since we already entered once)
bool scale_in_green_candle = close > open
bool scale_in_conditions = cond_price_above_ema and cond_volume_surge and cond_rsi_zone and cond_momentum and cond_regime and cond_cycle and cond_btc_above_200w and cond_stoch_oversold and cond_premium_expanding and cond_no_macd_div and cond_premium_cap and cond_halving
if p_use_scale_in and entry_count_this_cycle == 1 and strategy.opentrades > 0 and scale_in_green_candle and scale_in_conditions
    float remaining_pct = 1.0 - first_entry_pct
    strategy.entry("MOONSHOT_2", strategy.long, qty=strategy.equity * (p_risk_capital_pct / 100) * remaining_pct / close, comment="SCALE-IN [2/2]")
    entry_count_this_cycle := 2

// Hard exits
if exit_death_cross and strategy.opentrades > 0
    strategy.close_all(comment="BTC DEATH CROSS")

if exit_max_hold
    strategy.close_all(comment="MAX HOLD 18MO")

if exit_target
    strategy.close_all(comment="20X TARGET HIT")

// Exit when losing + below EMA 50 + volume spike (thesis broken)
if partial_exit_warning and strategy.opentrades > 0 and not exit_death_cross
    strategy.close_all(comment="BELOW EMA50 + LOSING")

// FALLBACK 1: BTC below 200-week MA — cycle support broken
if exit_btc_200w and current_pnl_pct < 0
    strategy.close_all(comment="BTC < 200W MA + LOSING")
else if exit_btc_200w and current_pnl_pct > 0
    strategy.close("MOONSHOT", comment="BTC < 200W MA PARTIAL", qty_percent=50)

// FALLBACK 2: Premium compression >30% — accelerate partial exit
if exit_premium_compress and current_pnl_pct > 0
    strategy.close("MOONSHOT", comment="PREMIUM COMPRESS -" + str.tostring(premium_drop_pct, "#") + "%", qty_percent=50)

// Initial floor exit (Phase 1 — before ladders activate)
if initial_floor_triggered
    strategy.close_all(comment="INITIAL FLOOR -" + str.tostring(p_initial_floor, "#") + "% from entry")

// Laddered trailing stop exit (Phase 2 — after +300%)
if ladder_trail_triggered
    strategy.close_all(comment="LADDER TRAIL STOP")

// v2.1: PANIC FLOOR — hard stop ONLY on losing positions (winners ride free)
// Prevents catastrophic single-position loss even when no trail is active (< +300%)
// Only triggers when stock_pnl_pct is negative (actual stock loss, not just LEAP-simulated)
// This lets winners that temporarily dip keep running while cutting true losers fast.
panic_floor_triggered = p_use_panic and strategy.opentrades > 0 and current_pnl_pct < -p_panic_floor and stock_pnl_pct < 0
if panic_floor_triggered
    strategy.close_all(comment="PANIC FLOOR -" + str.tostring(p_panic_floor, "#") + "%")

// Euphoria premium partial sell — if mNAV premium exceeds threshold while in profit
euphoria_sell_triggered = p_use_euphoria_sell and mstr_premium > p_euphoria_premium_sell and strategy.opentrades > 0 and current_pnl_pct > 0
if euphoria_sell_triggered
    strategy.close("MOONSHOT", comment="EUPHORIA PREMIUM >" + str.tostring(p_euphoria_premium_sell, "#.#") + "x", qty_percent=25)
    strategy.close("MOONSHOT_2", comment="EUPHORIA PREMIUM >" + str.tostring(p_euphoria_premium_sell, "#.#") + "x", qty_percent=25)

// ══════════════════════════════════════════════════════════════════════
// PLOTS & VISUALS
// ══════════════════════════════════════════════════════════════════════

// EMAs
plot(ema_entry, "EMA 21", color=color.new(color.aqua, 0), linewidth=1)
plot(ema_exit,  "EMA 50", color=color.new(color.orange, 0), linewidth=1)
plot(ema_200,   "EMA 200", color=color.new(color.white, 30), linewidth=2, style=plot.style_cross)

// Parabolic SAR
plot(p_show_sar ? sar_val : na, "Parabolic SAR", color=sar_bullish ? color.new(color.lime, 30) : color.new(color.red, 30), style=plot.style_circles, linewidth=1)

// MSTR 250-Week SMA (dip below then reclaim = entry trigger)
plot(mstr_250w_sma, "MSTR 250W SMA", color=color.new(#FFD700, 0), linewidth=3, style=plot.style_line)

// MSTR 250W cross markers — dip into cycle low zone + reclaim
plotshape(mstr_250w_cross_below, title="250W Dip Below", style=shape.circle, location=location.belowbar, color=color.new(color.aqua, 0), size=size.small, text="250W↓ DIP")
plotshape(mstr_250w_cross_above and mstr_dipped_below_250w, title="250W Reclaim", style=shape.circle, location=location.belowbar, color=color.new(#FFD700, 0), size=size.small, text="250W↑ RECLAIM")

// Regime background
bull_bg = p_show_bg and is_bull  ? color.new(color.green, 92) : na
bear_bg = p_show_bg and is_bear  ? color.new(color.red, 92)   : na
neut_bg = p_show_bg and btc_regime == "NEUTRAL" ? color.new(color.yellow, 95) : na
bgcolor(bull_bg, title="Bull Regime BG")
bgcolor(bear_bg, title="Bear Regime BG")
bgcolor(neut_bg, title="Neutral Regime BG")

// Entry window highlight
bgcolor(p_use_cycle and in_entry_window and is_post_halving ? color.new(color.lime, 94) : na, title="Cycle Entry Window")

// BTC 200-week MA breach warning (red background flash)
bgcolor(btc_200w_break and strategy.opentrades > 0 ? color.new(color.red, 80) : na, title="BTC 200W Break")

// Fallback exit shapes
plotshape(exit_btc_200w and strategy.opentrades > 0, title="BTC 200W Exit", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.normal, text="200W!")
plotshape(exit_premium_compress and current_pnl_pct > 0, title="Premium Compress", style=shape.xcross, location=location.abovebar, color=color.new(color.orange, 0), size=size.small, text="PREM!")

// Laddered trailing stop line
plot(ladder_trail_active ? ladder_trail_stop : na, "Ladder Trail Stop", color=color.new(#FF00FF, 0), linewidth=2, style=plot.style_stepline)

// Confluence status markers (shows when each piece activates, even without entry)
plotshape(p_use_confluence and confluence_confirmed and not confluence_confirmed[1], title="Confluence Confirmed", style=shape.labelup, location=location.belowbar, color=color.new(#00FF00, 0), size=size.normal, text="CONFLUENCE\n250W RECLAIM+SAR+RSI")

// Entry / exit arrows
entry_label = p_use_confluence ? "CONFLUENCE\nENTRY" : "250W RECLAIM ENTRY"
plotshape(regime_entry_ok and strategy.opentrades == 0, title="BUY Signal", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.normal, text="ENTRY")
plotshape(exit_death_cross and strategy.opentrades > 0, title="DEATH CROSS EXIT", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.normal, text="DC EXIT")
plotshape(partial_exit_warning and strategy.opentrades > 0 and not exit_death_cross, title="EMA50 Exit", style=shape.xcross, location=location.abovebar, color=color.orange, size=size.small, text="EMA50 EXIT")
plotshape(exit_target, title="TARGET HIT", style=shape.flag, location=location.abovebar, color=color.fuchsia, size=size.normal, text="20X!")
plotshape(sar_flip_bull, title="SAR Flip Bull", style=shape.diamond, location=location.belowbar, color=color.new(color.lime, 40), size=size.tiny)
plotshape(sar_flip_bear, title="SAR Flip Bear", style=shape.diamond, location=location.abovebar, color=color.new(color.red, 40), size=size.tiny)

// Initial floor exit marker (v2.1)
plotshape(initial_floor_triggered, title="INITIAL FLOOR", style=shape.triangledown, location=location.abovebar, color=color.new(color.orange, 0), size=size.normal, text="FLOOR!")

// Panic floor exit marker (v2.1)
plotshape(panic_floor_triggered, title="PANIC FLOOR", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.normal, text="PANIC!")

// MACD bearish divergence warning
plotshape(macd_div_warning, title="MACD Bearish Div", style=shape.xcross, location=location.abovebar, color=color.new(color.yellow, 0), size=size.small, text="DIV")

// Premium euphoria warning
plotshape(premium_peak_warning, title="Premium Peak", style=shape.circle, location=location.abovebar, color=color.new(color.fuchsia, 0), size=size.small, text="mNAV!")

// ══════════════════════════════════════════════════════════════════════
// DASHBOARD TABLE — 22 rows of moonshot intelligence
// ══════════════════════════════════════════════════════════════════════

if p_show_dash and barstate.islast
    var table dash = table.new(position.top_right, 2, 44, bgcolor=color.new(color.black, 15), border_width=1, border_color=color.gray, frame_width=2, frame_color=color.white)

    // Header
    table.cell(dash, 0, 0, "MOONSHOT DASH", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.purple, 20), text_halign=text.align_center)
    table.merge_cells(dash, 0, 0, 1, 0)

    regime_color  = is_bull ? color.lime : is_bear ? color.red : color.yellow
    regime_bg     = is_bull ? color.new(color.green, 70) : is_bear ? color.new(color.red, 70) : color.new(color.yellow, 70)

    // 1 — BTC Regime
    table.cell(dash, 0, 1, "BTC Regime",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 1, btc_regime,          text_color=regime_color, text_size=size.small, bgcolor=regime_bg, text_halign=text.align_right)

    // 2 — BTC Price
    table.cell(dash, 0, 2, "BTC Price",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 2, "$" + str.tostring(btc_close, "#,###"), text_color=btc_above_200 ? color.lime : color.red, text_size=size.small, text_halign=text.align_right)

    // 3 — mNAV Premium
    prem_color = premium_euphoria ? color.fuchsia : mstr_premium > 1.5 ? color.lime : mstr_premium > 1.0 ? color.yellow : color.red
    prem_bg = premium_euphoria ? color.new(color.fuchsia, 70) : color.new(color.black, 15)
    prem_text = str.tostring(mstr_premium, "#.##") + "x NAV"
    table.cell(dash, 0, 3, "mNAV Premium",     text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 3, prem_text,           text_color=prem_color,  text_size=size.small, bgcolor=prem_bg, text_halign=text.align_right)

    // 4 — MSTR-BTC Correlation
    corr_color = beta_corr > 0.7 ? color.lime : beta_corr > 0.4 ? color.yellow : color.red
    table.cell(dash, 0, 4, "MSTR-BTC Corr",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 4, str.tostring(beta_corr, "#.##"), text_color=corr_color, text_size=size.small, text_halign=text.align_right)

    // 5 — Implied Leverage
    lev_color = implied_lev > 2 ? color.lime : implied_lev > 1.2 ? color.yellow : color.white
    table.cell(dash, 0, 5, "Implied Lev",      text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 5, str.tostring(implied_lev, "#.#") + "x", text_color=lev_color, text_size=size.small, text_halign=text.align_right)

    // 6 — RSI
    rsi_color = rsi_val >= p_rsi_lo and rsi_val <= p_rsi_hi ? color.lime : rsi_val < 30 ? color.aqua : color.red
    table.cell(dash, 0, 6, "RSI (" + str.tostring(p_rsi_len) + ")", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 6, str.tostring(rsi_val, "#.#"), text_color=rsi_color, text_size=size.small, text_halign=text.align_right)

    // 7 — Stochastic RSI
    stoch_color = stoch_oversold ? color.aqua : stoch_overbought ? color.orange : color.white
    stoch_text = str.tostring(stoch_k_raw, "#.#") + (stoch_oversold ? " OS" : stoch_overbought ? " OB" : "")
    table.cell(dash, 0, 7, "Stoch RSI",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 7, stoch_text,          text_color=stoch_color, text_size=size.small, text_halign=text.align_right)

    // 8 — MACD
    macd_color = macd_bullish and macd_positive ? color.lime : macd_bullish ? color.yellow : color.red
    macd_text = macd_bullish ? "BULL" : "BEAR"
    macd_text := macd_bearish_div ? macd_text + " DIV!" : macd_text
    table.cell(dash, 0, 8, "MACD",             text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 8, macd_text,           text_color=macd_color,  text_size=size.small, text_halign=text.align_right)

    // 9 — Parabolic SAR
    sar_color = sar_bullish ? color.lime : color.red
    sar_text = sar_bullish ? "BULLISH" : "BEARISH"
    table.cell(dash, 0, 9, "Parabolic SAR",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 9, sar_text,            text_color=sar_color,   text_size=size.small, text_halign=text.align_right)

    // 10 — Volume Ratio
    vol_color = vol_ratio > p_vol_mult ? color.lime : color.white
    table.cell(dash, 0, 10, "Vol Ratio",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 10, str.tostring(vol_ratio, "#.##") + "x", text_color=vol_color, text_size=size.small, text_halign=text.align_right)

    // 11 — Momentum
    mom_color = mom_pct > p_mom_thresh ? color.lime : color.red
    table.cell(dash, 0, 11, "Momentum " + str.tostring(p_mom_len) + "d", text_color=color.gray, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 11, str.tostring(mom_pct, "#.#") + "%", text_color=mom_color, text_size=size.small, text_halign=text.align_right)

    // 12 — Key MAs Status
    ma_text = mstr_above_200 ? "Above 200" : "Below 200"
    ma_color = mstr_above_200 ? color.lime : color.red
    table.cell(dash, 0, 12, "MA Status",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 12, ma_text,            text_color=ma_color,    text_size=size.small, text_halign=text.align_right)

    // 13 — Entry Signal
    sig_text  = all_entry ? "FIRE" : str.tostring(entry_score) + "/10"
    sig_color = all_entry ? color.lime : entry_score >= 4 ? color.yellow : color.red
    sig_bg    = all_entry ? color.new(color.green, 60) : color.new(color.black, 15)
    table.cell(dash, 0, 13, "Entry Signal",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 13, sig_text,           text_color=sig_color,   text_size=size.small, bgcolor=sig_bg, text_halign=text.align_right)

    // 14 — Confirmations (now includes BTC golden cross as 5th confirmation)
    conf_text = str.tostring(confirm_score) + "/5"
    conf_color = confirm_score >= 4 ? color.lime : confirm_score >= 3 ? color.yellow : color.red
    table.cell(dash, 0, 14, "Confirms",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 14, conf_text,          text_color=conf_color,  text_size=size.small, text_halign=text.align_right)

    // 15 — Cycle Phase
    cyc_color = cycle_phase == "MARKUP" ? color.lime : cycle_phase == "EUPHORIA" ? color.fuchsia : cycle_phase == "ACCUMULATION" ? color.aqua : color.red
    table.cell(dash, 0, 15, "Cycle Phase",     text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 15, cycle_phase,        text_color=cyc_color,   text_size=size.small, text_halign=text.align_right)

    // 16 — Power Law Targets (BTC $200k scenario)
    table.cell(dash, 0, 16, "Target @BTC200k", text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 16, "$" + str.tostring(mstr_target_200k, "#,###"), text_color=color.new(#FFD700, 0), text_size=size.small, text_halign=text.align_right)

    // 17 — Entry Price
    entry_text = strategy.opentrades > 0 ? "$" + str.tostring(entry_px, "#.##") : "FLAT"
    entry_color = strategy.opentrades > 0 ? color.white : color.gray
    table.cell(dash, 0, 17, "Entry Price",     text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 17, entry_text,         text_color=entry_color, text_size=size.small, text_halign=text.align_right)

    // 18 — Current P&L
    pnl_text  = strategy.opentrades > 0 ? str.tostring(current_pnl_pct, "#.#") + "%" : "—"
    pnl_color = current_pnl_pct > 0 ? color.lime : current_pnl_pct < 0 ? color.red : color.gray
    table.cell(dash, 0, 18, "Open P&L",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 18, pnl_text,           text_color=pnl_color,   text_size=size.small, text_halign=text.align_right)

    // 19 — Bars in Trade
    hold_text  = strategy.opentrades > 0 ? str.tostring(bars_in_trade) + "/" + str.tostring(p_max_hold_bars) : "—"
    hold_color = bars_in_trade > p_max_hold_bars * 0.8 ? color.orange : color.white
    table.cell(dash, 0, 19, "Hold Bars",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 19, hold_text,          text_color=hold_color,  text_size=size.small, text_halign=text.align_right)

    // 20 — Ladder Tier
    tier_color = ladder_trail_active ? color.new(#FF00FF, 0) : initial_floor_active ? color.yellow : color.gray
    table.cell(dash, 0, 20, "Trail Tier",      text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 20, ladder_tier,        text_color=tier_color,  text_size=size.small, text_halign=text.align_right)

    // 21 — Trail Stop Price
    trail_text = ladder_trail_active ? "$" + str.tostring(ladder_trail_stop, "#.##") : initial_floor_active ? "$" + str.tostring(initial_floor_price, "#.##") + " (floor)" : "—"
    trail_color = ladder_trail_triggered ? color.red : initial_floor_triggered ? color.red : ladder_trail_active ? color.new(#FF00FF, 0) : initial_floor_active ? color.yellow : color.gray
    table.cell(dash, 0, 21, "Trail Stop",      text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 21, trail_text,         text_color=trail_color, text_size=size.small, text_halign=text.align_right)

    // 22 — Position Peak + Peak Gain
    hwm_text = strategy.opentrades > 0 ? "$" + str.tostring(hwm_val, "#.##") + " (+" + str.tostring(peak_gain_pct, "#") + "%)" : "—"
    table.cell(dash, 0, 22, "Pos Peak",         text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 22, hwm_text,           text_color=color.white, text_size=size.small, text_halign=text.align_right)

    // 23 — BTC 200-Week MA Status
    btc_200w_color = btc_200w_break ? color.red : color.lime
    btc_200w_text = btc_200w_break ? "BELOW — EXIT" : "ABOVE"
    table.cell(dash, 0, 23, "BTC 200W MA",      text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 23, btc_200w_text + " $" + str.tostring(btc_200w_ma, "#,###"), text_color=btc_200w_color, text_size=size.small, text_halign=text.align_right)

    // 24 — Premium Compression
    pcomp_color = premium_compressed ? color.red : premium_drop_pct > 15 ? color.orange : color.lime
    pcomp_text = strategy.opentrades > 0 ? "-" + str.tostring(premium_drop_pct, "#.#") + "% from peak" : "—"
    table.cell(dash, 0, 24, "Prem Compress",    text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 24, pcomp_text,          text_color=pcomp_color, text_size=size.small, text_halign=text.align_right)

    // 25 — MSTR 250W SMA (dip below → reclaim entry)
    m250w_color = mstr_250w_armed ? color.lime : (mstr_dipped_below_250w and mstr_above_250w) ? color.yellow : mstr_below_250w ? color.aqua : color.red
    m250w_text = mstr_250w_armed ? "RECLAIM ARMED (" + str.tostring(mstr_green_count) + ")" : (mstr_dipped_below_250w and mstr_above_250w) ? "RECLAIMING (" + str.tostring(mstr_green_count) + "/" + str.tostring(p_mstr_green_weeks) + ")" : mstr_below_250w ? "DIPPED BELOW ✓" : mstr_dipped_below_250w ? "DIP FLAG SET" : "ABOVE (waiting for dip)"
    m250w_bg = mstr_250w_armed ? color.new(color.green, 70) : mstr_below_250w ? color.new(color.aqua, 80) : color.new(color.black, 15)
    table.cell(dash, 0, 25, "MSTR 250W",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 25, m250w_text,          text_color=m250w_color, text_size=size.small, bgcolor=m250w_bg, text_halign=text.align_right)

    // 26 — MSTR 250W SMA Price Level
    table.cell(dash, 0, 26, "250W SMA",          text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 26, "$" + str.tostring(mstr_250w_sma, "#.##"), text_color=mstr_below_250w ? color.aqua : mstr_above_250w ? color.lime : color.gray, text_size=size.small, text_halign=text.align_right)

    // 27 — RSI Capitulation Status (shows if flag was ever set in loaded chart history)
    rsi_cap_color = rsi_recovering ? color.lime : rsi_hit_capitulation ? color.yellow : rsi_val < p_rsi_capitulation ? color.aqua : color.red
    rsi_cap_text = rsi_recovering ? "RECOVERING ↑" : rsi_hit_capitulation ? "FLAG SET (wait)" : rsi_val < p_rsi_capitulation ? "CAPITULATION" : "NEVER HIT <" + str.tostring(p_rsi_capitulation, "#")
    table.cell(dash, 0, 27, "RSI Capit",         text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 27, rsi_cap_text + " (" + str.tostring(rsi_val, "#.#") + ")", text_color=rsi_cap_color, text_size=size.small, text_halign=text.align_right)

    // 28 — SAR Confirmation Status
    sar_conf_color = sar_confirmed ? color.lime : sar_bullish ? color.yellow : color.red
    sar_conf_text = sar_confirmed ? "CONFIRMED (" + str.tostring(sar_bull_count) + "d)" : sar_bullish ? "BULL (" + str.tostring(sar_bull_count) + "/" + str.tostring(p_sar_confirm_bars) + ")" : "BEARISH"
    table.cell(dash, 0, 28, "SAR Confirm",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 28, sar_conf_text,        text_color=sar_conf_color, text_size=size.small, text_halign=text.align_right)

    // 29 — Confluence Gate
    conf_gate_color = confluence_confirmed ? color.lime : color.red
    conf_gate_bg = confluence_confirmed ? color.new(color.green, 60) : color.new(color.red, 80)
    conf_gate_text = confluence_confirmed ? "ALL 3 ✓ FIRE" : (mstr_250w_armed ? "1" : "0") + "+" + (sar_confirmed ? "1" : "0") + "+" + (rsi_recovering ? "1" : "0") + " /3"
    table.cell(dash, 0, 29, "Confluence",         text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 29, conf_gate_text,        text_color=conf_gate_color, text_size=size.small, bgcolor=conf_gate_bg, text_halign=text.align_right)

    // 30 — LEAP Multiplier (v2.1: shows dynamic with premium boost)
    leap_mult_color = premium_boost > 1.0 ? color.lime : color.white
    leap_mult_text = str.tostring(dynamic_leap_mult, "#.#") + "x" + (premium_boost > 1.0 ? " (+" + str.tostring((premium_boost - 1) * 100, "#") + "% boost)" : "")
    table.cell(dash, 0, 30, "LEAP Mult",          text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 30, leap_mult_text,        text_color=leap_mult_color, text_size=size.small, text_halign=text.align_right)

    // 31 — Risk Capital (v2.1)
    table.cell(dash, 0, 31, "Risk Capital",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 31, str.tostring(p_risk_capital_pct, "#") + "% of account", text_color=color.aqua, text_size=size.small, text_halign=text.align_right)

    // 32 — Panic Floor (v2.1)
    panic_color = panic_floor_triggered ? color.red : p_use_panic ? color.yellow : color.gray
    panic_text = p_use_panic ? "-" + str.tostring(p_panic_floor, "#") + "% LEAP" + (panic_floor_triggered ? " TRIGGERED!" : "") : "OFF"
    table.cell(dash, 0, 32, "Panic Floor",         text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 32, panic_text,             text_color=panic_color, text_size=size.small, text_halign=text.align_right)

    // 33 — Expected Live Return (v2.1 realism)
    table.cell(dash, 0, 33, "Expected Live",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 33, "Flat to +30-50%",      text_color=color.aqua,  text_size=size.small, text_halign=text.align_right)

    // 34 — Slippage & Commission (v2.1 info row)
    table.cell(dash, 0, 34, "Slippage/Comm",       text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 34, "10 ticks / 1.5%",     text_color=color.gray,  text_size=size.small, text_halign=text.align_right)

    // 35 — Version
    table.cell(dash, 0, 35, "Version",             text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 35, "v2.2b 30% Floor",     text_color=color.new(#FFD700, 0), text_size=size.small, text_halign=text.align_right)

    // 36 — Distance to 250W SMA
    float dist_250w_pct = mstr_250w_sma > 0 ? ((close - mstr_250w_sma) / mstr_250w_sma * 100) : 0
    color dist_250w_color = dist_250w_pct < 0 ? color.lime : dist_250w_pct < 50 ? color.yellow : color.red
    table.cell(dash, 0, 36, "Dist to 250W",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 36, str.tostring(dist_250w_pct, "#.#") + "%", text_color=dist_250w_color, text_size=size.small, text_halign=text.align_right)

    // 37 — Est. Contracts
    float est_contract_cost = close * (p_avg_contract_cost / 100)
    int est_contracts = est_contract_cost > 0 ? math.floor(p_total_capital / est_contract_cost) : 0
    table.cell(dash, 0, 37, "Est. Contracts",      text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 37, str.tostring(est_contracts) + " @ $" + str.tostring(est_contract_cost, "#.##"), text_color=color.aqua, text_size=size.small, text_halign=text.align_right)

    // 38 — Expected P&L (Base Case)
    table.cell(dash, 0, 38, "Expected P&L",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 38, "~$11M-$17M (88-130x)", text_color=color.new(#FFD700, 0), text_size=size.small, text_halign=text.align_right)

    // 39 — Max Risk
    float max_risk_dollars = strategy.initial_capital * p_risk_capital_pct / 100
    table.cell(dash, 0, 39, "Max Risk",            text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 39, "$" + str.tostring(max_risk_dollars, "#,###"), text_color=color.orange, text_size=size.small, text_halign=text.align_right)

    // 40 — Chart Timeframe
    color tf_color = timeframe.ismonthly ? color.lime : timeframe.isweekly ? color.yellow : color.red
    string tf_text = timeframe.ismonthly ? "Monthly" : timeframe.isweekly ? "Weekly" : timeframe.isdaily ? "Daily" : timeframe.period
    table.cell(dash, 0, 40, "Chart TF",            text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 40, tf_text,                text_color=tf_color,    text_size=size.small, text_halign=text.align_right)

    // 41 — Halving Cycle Year
    color cy_color = cycle_year == 0 or cycle_year == 1 ? color.lime : cycle_year == 2 ? color.yellow : color.red
    string cy_text = "Year " + str.tostring(cycle_year) + (cycle_year == 0 or cycle_year == 1 ? " (optimal)" : cycle_year == 2 ? " (caution)" : " (avoid)")
    table.cell(dash, 0, 41, "Halving Year",        text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 41, cy_text,                text_color=cy_color,    text_size=size.small, text_halign=text.align_right)

    // 42 — BTC 200W Status (Entry Filter)
    bool btc_above_200w_status = not btc_below_200w
    color btc200w_filt_color = btc_above_200w_status ? color.lime : color.red
    string btc200w_filt_text = btc_above_200w_status ? "ABOVE (PASS)" : "BELOW (FAIL)"
    table.cell(dash, 0, 42, "BTC 200W Filter",     text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 42, btc200w_filt_text,      text_color=btc200w_filt_color, text_size=size.small, text_halign=text.align_right)

    // 43 — Stoch RSI Entry
    color stoch_filt_color = stoch_k_raw < p_stoch_entry_thresh ? color.lime : color.red
    string stoch_filt_text = str.tostring(stoch_k_raw, "#.#") + (stoch_k_raw < p_stoch_entry_thresh ? " (PASS <" + str.tostring(p_stoch_entry_thresh, "#") + ")" : " (FAIL >=" + str.tostring(p_stoch_entry_thresh, "#") + ")")
    table.cell(dash, 0, 43, "Stoch RSI Filt",      text_color=color.gray,  text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 43, stoch_filt_text,         text_color=stoch_filt_color, text_size=size.small, text_halign=text.align_right)

// ══════════════════════════════════════════════════════════════════════
// ALERT CONDITIONS
// ══════════════════════════════════════════════════════════════════════

alertcondition(all_entry and strategy.opentrades == 0, title="MOONSHOT BUY", message="MSTR MOONSHOT ENTRY — All 6 conditions met. MSTR 250W dip+reclaim confirmed + volume surge + momentum. Load LEAP calls.")

alertcondition(confluence_confirmed and not confluence_confirmed[1], title="CONFLUENCE CONFIRMED", message="CYCLE LOW CONFLUENCE — 250W dip+reclaim armed + SAR bullish confirmed + RSI recovering from capitulation. Maximum conviction entry signal. LOAD LEAPs.")

alertcondition(rsi_recovering and not rsi_recovering[1], title="RSI RECOVERY", message="MSTR RSI recovering from capitulation — now rising above threshold. Watch for confluence with 250W reclaim + SAR.")

alertcondition(mstr_250w_cross_below, title="MSTR 250W DIP", message="MSTR weekly close dropped BELOW 250-week SMA — cycle low zone entered. Dip flag SET. Watch for reclaim.")

alertcondition(mstr_250w_cross_above and mstr_dipped_below_250w, title="MSTR 250W RECLAIM", message="MSTR reclaiming 250-week SMA after dip — counting green candles above. Entry ARMs after consecutive greens.")

alertcondition(mstr_250w_armed and not mstr_250w_armed[1], title="MSTR 250W ARMED", message="MSTR 250W dip+reclaim ARMED — consecutive green candles above 250W after cycle-low dip. Entry gate OPEN.")

alertcondition(mstr_below_250w and mstr_above_250w[1], title="MSTR 250W LOST", message="MSTR dropped back BELOW 250-week SMA — reclaim failed, green counter RESET.")

alertcondition(exit_death_cross, title="BTC DEATH CROSS EXIT", message="BTC DEATH CROSS — 50 SMA below 200 SMA. EXIT ALL MSTR LEAPs immediately.")

alertcondition(partial_exit_warning, title="EMA50 LOSING EXIT", message="MSTR below EMA 50 with volume spike AND position losing — full exit.")

alertcondition(exit_max_hold, title="MAX HOLD REACHED", message="MSTR MOONSHOT 18-month max hold reached. Close or roll LEAP positions.")

alertcondition(exit_target, title="20X TARGET HIT", message="MSTR MOONSHOT 20X TARGET REACHED — take profits on LEAP positions.")

alertcondition(ladder_trail_triggered, title="LADDER TRAIL STOP", message="MSTR MOONSHOT laddered trailing stop triggered — EXIT LEAP positions.")

alertcondition(exit_btc_200w, title="BTC 200-WEEK MA BREAK", message="BTC dropped below 200-week MA — cycle support broken. If losing: full exit. If profitable: sell 50%.")

alertcondition(exit_premium_compress, title="PREMIUM COMPRESSION", message="MSTR mNAV premium compressed >30% from peak — accelerating partial exit (50%).")

alertcondition(initial_floor_triggered, title="INITIAL FLOOR HIT", message="MSTR MOONSHOT INITIAL FLOOR — Stock dropped below entry floor before ladders activated. Full exit triggered.")

alertcondition(panic_floor_triggered, title="PANIC FLOOR HIT", message="MSTR MOONSHOT PANIC FLOOR — LEAP-equivalent P&L dropped below hard stop threshold. Full exit triggered.")

alertcondition(premium_peak_warning, title="PREMIUM EUPHORIA", message="MSTR mNAV premium at euphoria levels during run — consider partial profit-taking.")

alertcondition(macd_div_warning, title="MACD DIVERGENCE", message="MSTR MACD bearish divergence detected during run — early exhaustion warning.")

alertcondition(sar_flip_bull, title="SAR FLIP BULLISH", message="MSTR Parabolic SAR flipped bullish — dots below price, trend confirmed.")

alertcondition(sar_flip_bear, title="SAR FLIP BEARISH", message="MSTR Parabolic SAR flipped bearish — dots above price, trend weakening.")

// Regime change alerts
bull_to_bear = is_bear and is_bull[1]
bear_to_bull = is_bull and is_bear[1]
alertcondition(bull_to_bear, title="REGIME: BULL->BEAR", message="BTC regime changed BULL to BEAR. No new MSTR LEAP entries. Review open positions.")
alertcondition(bear_to_bull, title="REGIME: BEAR->BULL", message="BTC regime changed BEAR to BULL. MSTR LEAP entry window opening.")

// Stochastic RSI oversold bounce (reload zone during bull run)
alertcondition(stoch_oversold and is_bull, title="STOCH OVERSOLD IN BULL", message="MSTR Stochastic RSI oversold during BTC bull regime — potential reload zone for LEAP positions.")

alertcondition(pt1_hit and not pt1_hit[1], title="PT1 5x Hit", message="MSTR MOONSHOT 5x — sold 25% of contracts (+500%)")
alertcondition(pt2_hit and not pt2_hit[1], title="PT2 10x Hit", message="MSTR MOONSHOT 10x — sold 25% of contracts (+1000%)")
alertcondition(pt3_hit and not pt3_hit[1], title="PT3 20x Hit", message="MSTR MOONSHOT 20x — sold 25% of contracts (+2000%)")
alertcondition(pt3_hit and not pt3_hit[1], title="LEAP ROLL ALERT 20x", message="MSTR MOONSHOT 20x HIT — Consider rolling 25% of LEAP contracts to next expiration to lock gains and extend exposure.")
alertcondition(pt4_hit and not pt4_hit[1], title="PT4 50x Hit", message="MSTR MOONSHOT 50x — sold final 25% of contracts (+5000%)")
alertcondition(euphoria_sell_triggered and not euphoria_sell_triggered[1], title="EUPHORIA PREMIUM SELL", message="MSTR mNAV premium exceeded euphoria threshold — selling 25% of position to lock premium gains.")
alertcondition(p_use_scale_in and entry_count_this_cycle == 2 and entry_count_this_cycle[1] == 1, title="SCALE-IN COMPLETE", message="MSTR MOONSHOT scale-in complete — second tranche deployed on green candle confirmation.")
