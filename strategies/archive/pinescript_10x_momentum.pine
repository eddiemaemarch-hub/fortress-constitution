//@version=6
// Rudy v2 - 10x Momentum Runner Strategy
// Share-based momentum on high-growth names — alerts fire for Trader to execute options
// Tuned for IONQ daily: 8% position, 15% target, 6% stop, trail catches runners
// Apply to: IONQ, RGTI, QBTS, SMCI, AFRM, RKLB, HOOD, UPST
strategy("Rudy 10x Momentum v1", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=8, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.5, slippage=5, pyramiding=0)

// --- Core Parameters ---
p_ema_fast   = input.int(10, "Fast EMA", group="Momentum")
p_ema_mid    = input.int(21, "Mid EMA", group="Momentum")
p_ema_slow   = input.int(50, "Slow EMA", group="Momentum")
p_rsi        = input.int(14, "RSI Period", group="Momentum")
p_macd_f     = input.int(12, "MACD Fast", group="Momentum")
p_macd_s     = input.int(26, "MACD Slow", group="Momentum")
p_macd_sig   = input.int(9, "MACD Signal", group="Momentum")
p_atr_len    = input.int(14, "ATR Length", group="Momentum")

// --- Risk Management ---
p_profit     = input.float(15.0, "Profit Target %", group="Risk") / 100
p_atr_mult   = input.float(1.8, "ATR Stop Multiplier", group="Risk")
p_trail_en   = input.bool(true, "Enable Trailing Stop", group="Risk")
p_trail_act  = input.float(8.0, "Trail Activation %", group="Risk") / 100
p_trail_off  = input.float(4.0, "Trail Offset %", group="Risk") / 100
p_max_bars   = input.int(40, "Max Hold Bars", group="Risk")
p_hwm_trail_pct = input.float(30.0, "HWM Trail Floor %", group="Risk")
p_hwm_lookback  = input.int(252, "HWM Lookback Bars", group="Risk")

// Laddered Trailing Stop (tightens as gains grow)
p_lad_t1_gain  = input.float(50,   "Ladder Tier 1 at +%", group="Laddered Trail")   // was 100
p_lad_t1_trail = input.float(25.0, "Ladder Tier 1 Trail %", group="Laddered Trail") // was 30
p_lad_t2_gain  = input.float(100,  "Ladder Tier 2 at +%", group="Laddered Trail")   // was 300
p_lad_t2_trail = input.float(20.0, "Ladder Tier 2 Trail %", group="Laddered Trail") // was 25
p_lad_t3_gain  = input.float(200,  "Ladder Tier 3 at +%", group="Laddered Trail")   // was 500
p_lad_t3_trail = input.float(15.0, "Ladder Tier 3 Trail %", group="Laddered Trail") // was 20

// --- Profit Taking ---
p_pt_tier1_pct  = input.float(100.0, "Tier 1 Profit %", group="Profit Taking")
p_pt_tier1_sell = input.float(25.0, "Tier 1 Sell %", group="Profit Taking")
p_pt_tier2_pct  = input.float(300.0, "Tier 2 Profit %", group="Profit Taking")
p_pt_tier2_sell = input.float(25.0, "Tier 2 Sell %", group="Profit Taking")
p_pt_tier3_pct  = input.float(500.0, "Tier 3 Profit %", group="Profit Taking")
p_pt_tier3_sell = input.float(25.0, "Tier 3 Sell %", group="Profit Taking")

// --- Filters ---
p_use_spy    = input.bool(true, "SPY Market Filter", group="Filters")
p_spy_ticker = input.symbol("SPY", "SPY Symbol", group="Filters")

// --- SPY Filter (non-repainting) ---
spy_close = request.security(p_spy_ticker, timeframe.period, close, barmerge.gaps_off, barmerge.lookahead_off)
spy_ema50 = request.security(p_spy_ticker, timeframe.period, ta.ema(close, 50), barmerge.gaps_off, barmerge.lookahead_off)
spy_bullish = spy_close > spy_ema50

// --- Calculations ---
emaFast = ta.ema(close, p_ema_fast)
emaMid = ta.ema(close, p_ema_mid)
emaSlow = ta.ema(close, p_ema_slow)
rsiVal = ta.rsi(close, p_rsi)
[mLine, sLine, mHist] = ta.macd(close, p_macd_f, p_macd_s, p_macd_sig)
atr_val = ta.atr(p_atr_len)
vol_avg = ta.sma(volume, 20)
volRatio = volume / vol_avg
mom10 = (close - close[10]) / close[10] * 100
mom20 = (close - close[20]) / close[20] * 100

// --- EMA Stack Detection (10 > 21 > 50 = power trend) ---
emaStack = emaFast > emaMid and emaMid > emaSlow

// --- Entry Logic ---
// Power trend (stacked EMAs) + MACD bullish + momentum + not overbought
buySignal = emaStack and close > emaFast and mHist > 0 and rsiVal < 78 and rsiVal > 35
buySignal := buySignal and (not p_use_spy or spy_bullish)

// --- Exit Logic ---
// Only exit on real trend break — close below slow EMA
trendLost = ta.crossunder(close, emaSlow)
// Or EMA stack breaks
stackBroken = emaMid < emaSlow

inPosition = strategy.position_size > 0
flat = strategy.position_size == 0
bars_in_trade = ta.barssince(flat[1] and not flat)
max_hold_exit = p_max_bars > 0 and inPosition and bars_in_trade >= p_max_bars

// --- Profit Taking Tiers ---
var bool pt_tier1_done = false
var bool pt_tier2_done = false
var bool pt_tier3_done = false

if strategy.opentrades > 0
    entry_price_pt = strategy.opentrades.entry_price(0)
    gain_pct_pt = (close - entry_price_pt) / entry_price_pt * 100

    if gain_pct_pt >= p_pt_tier1_pct and not pt_tier1_done
        strategy.close(strategy.opentrades.entry_id(0), comment="PROFIT T1 +" + str.tostring(p_pt_tier1_pct, "#") + "%", qty_percent=p_pt_tier1_sell)
        pt_tier1_done := true

    if gain_pct_pt >= p_pt_tier2_pct and not pt_tier2_done
        strategy.close(strategy.opentrades.entry_id(0), comment="PROFIT T2 +" + str.tostring(p_pt_tier2_pct, "#") + "%", qty_percent=p_pt_tier2_sell)
        pt_tier2_done := true

    if gain_pct_pt >= p_pt_tier3_pct and not pt_tier3_done
        strategy.close(strategy.opentrades.entry_id(0), comment="PROFIT T3 +" + str.tostring(p_pt_tier3_pct, "#") + "%", qty_percent=p_pt_tier3_sell)
        pt_tier3_done := true

// Reset on new trade
if strategy.opentrades == 0
    pt_tier1_done := false
    pt_tier2_done := false
    pt_tier3_done := false

// --- Execution ---
if buySignal and flat
    strategy.entry("10X_Long", strategy.long)
    stopPrice = close - (atr_val * p_atr_mult)
    if p_trail_en
        strategy.exit("10X_Exit", "10X_Long", stop=stopPrice, limit=close * (1 + p_profit), trail_price=close * (1 + p_trail_act), trail_offset=close * p_trail_off)
    else
        strategy.exit("10X_Exit", "10X_Long", stop=stopPrice, limit=close * (1 + p_profit))

if trendLost and inPosition
    strategy.close("10X_Long", comment="Trend Lost")

if stackBroken and inPosition
    strategy.close("10X_Long", comment="Stack Broken")

if max_hold_exit
    strategy.close("10X_Long", comment="Max Hold")

// --- LADDERED Trailing Stop from HWM (Constitution v45.0) ---
var float pos_hwm = 0.0
if inPosition
    pos_hwm := math.max(pos_hwm, high)
if flat
    pos_hwm := 0.0
hwm_val = pos_hwm > 0 ? pos_hwm : close
float entry_px_lad = strategy.position_avg_price
float gain_pct_lad = entry_px_lad > 0 ? (close - entry_px_lad) / entry_px_lad * 100 : 0
float peak_gain_pct = inPosition and entry_px_lad > 0 ? (pos_hwm - entry_px_lad) / entry_px_lad * 100 : 0

// Select trail % based on PEAK gain tier (prevents tier downgrade on pullback)
var float active_trail = p_hwm_trail_pct
var string ladder_tier_str = "30% (floor)"

if inPosition
    if peak_gain_pct >= p_lad_t3_gain
        active_trail := p_lad_t3_trail
        ladder_tier_str := str.tostring(p_lad_t3_gain,"#") + "%+ | " + str.tostring(p_lad_t3_trail,"#") + "% LOCK"
    else if peak_gain_pct >= p_lad_t2_gain
        active_trail := p_lad_t2_trail
        ladder_tier_str := str.tostring(p_lad_t2_gain,"#") + "%+ | " + str.tostring(p_lad_t2_trail,"#") + "% trail"
    else if peak_gain_pct >= p_lad_t1_gain
        active_trail := p_lad_t1_trail
        ladder_tier_str := str.tostring(p_lad_t1_gain,"#") + "%+ | " + str.tostring(p_lad_t1_trail,"#") + "% trail"
    else
        active_trail := p_hwm_trail_pct
        ladder_tier_str := str.tostring(p_hwm_trail_pct,"#") + "% (floor)"
else
    active_trail := p_hwm_trail_pct
    ladder_tier_str := str.tostring(p_hwm_trail_pct,"#") + "% (floor)"

hwm_trail_stop = hwm_val * (1 - active_trail / 100)
hwm_trail_triggered = inPosition and close < hwm_trail_stop
if hwm_trail_triggered
    strategy.close("10X_Long", comment="Ladder Trail " + str.tostring(active_trail,"#") + "%")

// --- Visuals ---
plot(emaFast, "EMA 10", color.new(#00E676, 0), 1)
plot(emaMid, "EMA 21", color.new(#2196F3, 0), 2)
plot(emaSlow, "EMA 50", color.new(#FF5722, 0), 2)
barcolor(volRatio > 2.0 ? color.new(#FFD700, 0) : na)
bgcolor(emaStack ? color.new(#4CAF50, 95) : na)
plotshape(buySignal and flat, "Buy", shape.triangleup, location.belowbar, color.new(#00E676, 0), size=size.small, text="BUY")
plotshape(trendLost and inPosition, "Exit", shape.triangledown, location.abovebar, color.new(#F44336, 0), size=size.small, text="SELL")
plotshape(stackBroken and inPosition, "Stack Break", shape.xcross, location.abovebar, color.new(#FF9800, 0), size=size.small, text="STACK")
plotshape(max_hold_exit, "Max Hold", shape.xcross, location.abovebar, color.new(#FF9800, 0), size=size.tiny, text="MH")
plotshape(strategy.opentrades > 0 and pt_tier1_done and not pt_tier1_done[1], "PT1 Hit", shape.flag, location.abovebar, color.new(#00E676, 0), size=size.tiny, text="PT1")
plotshape(strategy.opentrades > 0 and pt_tier2_done and not pt_tier2_done[1], "PT2 Hit", shape.flag, location.abovebar, color.new(#00BCD4, 0), size=size.tiny, text="PT2")
plotshape(strategy.opentrades > 0 and pt_tier3_done and not pt_tier3_done[1], "PT3 Hit", shape.flag, location.abovebar, color.new(#FFD700, 0), size=size.tiny, text="PT3")
plot(inPosition ? strategy.position_avg_price - (atr_val * p_atr_mult) : na, "ATR Stop", color.new(color.red, 0), 1, plot.style_circles)
plot(inPosition ? hwm_trail_stop : na, "HWM Trail Stop", color.new(#FF00FF, 0), 2, plot.style_stepline)

// --- Dashboard ---
var table dash = table.new(position.top_right, 2, 18, bgcolor=color.new(#000000, 80), border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "10X RUNNER", text_color=color.new(#FFD700, 0), text_size=size.normal)
    table.cell(dash, 1, 0, emaStack ? "STACKED" : "NO STACK", text_color=emaStack ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 1, "RSI", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(rsiVal, "#.#"), text_color=rsiVal < 78 ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 2, "MACD", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, mHist > 0 ? "BULL" : "BEAR", text_color=mHist > 0 ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 3, "Mom10d", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(mom10, "#.#") + "%", text_color=mom10 > 0 ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 4, "Mom20d", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(mom20, "#.#") + "%", text_color=mom20 > 0 ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 5, "Volume", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(volRatio, "#.#") + "x", text_color=volRatio > 1.5 ? color.lime : color.gray, text_size=size.small)
    table.cell(dash, 0, 6, "SPY", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, p_use_spy ? (spy_bullish ? "BULL" : "BEAR") : "OFF", text_color=p_use_spy ? (spy_bullish ? color.lime : color.red) : color.gray, text_size=size.small)
    table.cell(dash, 0, 7, "Hold", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 7, inPosition ? str.tostring(bars_in_trade) + "/" + str.tostring(p_max_bars) : "-", text_color=max_hold_exit ? color.orange : color.white, text_size=size.small)
    table.cell(dash, 0, 8, "P&L", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 8, inPosition ? str.tostring((close - strategy.position_avg_price) / strategy.position_avg_price * 100, "#.#") + "%" : "-", text_color=inPosition and close > strategy.position_avg_price ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 9, "Peak Gain", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 9, inPosition ? str.tostring(peak_gain_pct, "+#.#") + "%" : "-", text_color=color.new(#FFD700, 0), text_size=size.small)
    table.cell(dash, 0, 10, "Pos Peak", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 10, inPosition ? "$" + str.tostring(pos_hwm, "#.##") : "-", text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 11, "Trail Tier", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 11, ladder_tier_str, text_color=gain_pct_lad >= p_lad_t3_gain ? color.new(#FFD700, 0) : gain_pct_lad >= p_lad_t1_gain ? color.new(#FF00FF, 0) : color.gray, text_size=size.small)
    table.cell(dash, 0, 12, "Trail %", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 12, str.tostring(active_trail, "#") + "% from peak", text_color=color.new(#FF00FF, 0), text_size=size.small)
    table.cell(dash, 0, 13, "Trail Price", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 13, inPosition ? str.tostring(hwm_trail_stop, "#.##") : "-", text_color=hwm_trail_triggered ? color.red : color.new(#FF00FF, 0), text_size=size.small)
    table.cell(dash, 0, 14, "Profit T1", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 14, str.tostring(p_pt_tier1_pct, "#") + "% → " + str.tostring(p_pt_tier1_sell, "#") + "% sell" + (pt_tier1_done ? " ✓" : ""), text_color=pt_tier1_done ? color.lime : color.gray, text_size=size.small)
    table.cell(dash, 0, 15, "Profit T2", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 15, str.tostring(p_pt_tier2_pct, "#") + "% → " + str.tostring(p_pt_tier2_sell, "#") + "% sell" + (pt_tier2_done ? " ✓" : ""), text_color=pt_tier2_done ? color.lime : color.gray, text_size=size.small)
    table.cell(dash, 0, 16, "Profit T3", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 16, str.tostring(p_pt_tier3_pct, "#") + "% → " + str.tostring(p_pt_tier3_sell, "#") + "% sell" + (pt_tier3_done ? " ✓" : ""), text_color=pt_tier3_done ? color.lime : color.gray, text_size=size.small)

alertcondition(buySignal and flat, "10x Buy", "10x Runner BUY — Trader execute CALL options")
alertcondition(trendLost and inPosition, "Trend Lost", "Trend lost — Trader close calls")
alertcondition(stackBroken and inPosition, "Stack Broken", "EMA stack broken — Trader close calls")
alertcondition(max_hold_exit, "Max Hold", "Max hold — Trader close position")
alertcondition(hwm_trail_triggered, "Ladder Trail", "Laddered trailing stop triggered — Trader close position")
alertcondition(strategy.opentrades > 0 and pt_tier1_done and not pt_tier1_done[1], "Profit T1", "Profit Tier 1 hit — sold 25% at +100%")
alertcondition(strategy.opentrades > 0 and pt_tier2_done and not pt_tier2_done[1], "Profit T2", "Profit Tier 2 hit — sold 25% at +300%")
alertcondition(strategy.opentrades > 0 and pt_tier3_done and not pt_tier3_done[1], "Profit T3", "Profit Tier 3 hit — sold 25% at +500%")
