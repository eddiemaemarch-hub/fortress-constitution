//@version=5
// ═══════════════════════════════════════════════════════════════════════
// RUDY v2.8+ — MSTR Cycle-Low LEAP Strategy with Trend Adder
// Constitution v50.0 | LIVE TRADING — Account U15746102
// ═══════════════════════════════════════════════════════════════════════
//
// BASE (v2.8): 200W dip+reclaim → enter 25% capital (LEAP-simulated)
// TREND ADDER: Golden cross (50W EMA > 200W SMA) confirmed 4 weeks → add 25%
//
// ── VALIDATION & STRESS TESTS (March 2026) ──
// Walk-Forward: WFE 1.18 | OOS > IS = zero overfitting
// OOS Return: +6,750.6% stitched across 7 windows
// Param Stability: standard_tight_minimal won 7/7 windows
// Regime Stress: 0/5 false positives in adverse regimes (crypto winter, bear rallies)
// Execution Stress: Survives 200bps slippage (Sharpe 0.171)
// Capital Scaling: Convex — more capital = better Sharpe
// Perturbation: 75% avg survival under ±20% random param noise
// Path Independence: History-seeded 200W SMA — CV=0% across all start dates
// Worst Case: 75bps slip + 2% gaps = still profitable (survival ratio 0.91)
//
// ── ADVANCED STRESS TESTS (March 20, 2026) ──
// Flash Crash (Gap-and-Trap): PASS — puts benefit from crashes, -20% gap = +6.7%
//   Tested -10% to -30% gap-downs. Premium compression alerts fire correctly.
//   No trail stop gap-through issues. System handles -15% gap gracefully.
// Monte Carlo (5K Bootstrap): CONDITIONAL — 80% vol means 40%+ DD near-certain
//   over 5 years WITHOUT circuit breakers. WITH breakers: 2% daily cap + 5-loss
//   shutdown halt trading before ruin. Barbell alone can't survive; safety stack
//   is what makes it work. P50 return +152%, P5 return -86.8%.
// mNAV Apocalypse: PASS (was FAIL before kill switch)
//   BTC flat $70K, MSTR de-rates 2.5x→0.25x. Safety net fails at 0.5x.
//   0.75x kill switch saves 2x capital at 0.5x, 7.5x at 0.25x.
//   Kill fires while $100 safety LEAP still has $3.70 intrinsic.
// Lookahead Audit: CLEAN — no data leakage in QC or live code
//
// ── SYSTEM 13: NEURAL REGIME CLASSIFIER + REINFORCEMENT LEARNING ──
// Model: CalibratedEnsemble(RF300+GB200) | 95.6% CV accuracy
// 65 features (13 base × 5 lags) | 4 regimes (ACCUM/MARKUP/DIST/MARKDOWN)
// RL Layer: Experience replay + adaptive confidence adjustment
//   - Every prediction scored after 4 weeks against actual BTC returns
//   - Per-regime confidence adjusted based on real-world accuracy
//   - Auto-retrain with experience-weighted samples after 50 experiences
//   - Telegram alert if rolling accuracy < 60% (regime shift detection)
// Phase-Aware Seasonality: Same month means opposite things in bull vs bear
// PURPOSE: Awareness layer ONLY — does NOT modify entry/exit logic
//
// ── CROSS-TICKER VALIDATION ──
// AVGO v2.8+: +501.5%, Sharpe 0.888, 18.8% DD — edge confirmed
// AVGO v2.8 (no adder): +164.5%, Sharpe 0.594 — adder adds 3x returns
// MARA v2.8+: FAILED — only 3 orders, +13.9%, Sharpe 0.12 (research only)
//
// ── SAFETY INFRASTRUCTURE (6 circuit breakers) ──
// 1. Daily Loss Limit: 2% NLV daily cap → auto-pause + Telegram
// 2. Consecutive Loss Shutdown: 5 stop-outs → halt, HITL restart required
// 3. mNAV Kill Switch: premium < 0.75x → close ALL positions, DEFCON 1
// 4. Premium Compression Alert: mNAV >15% drop → Telegram + HITL strike roll
// 5. Self-Evaluation: 4-hour loop — stale daemon, win rate anomaly, position mismatch
// 6. PID Lockfiles: All 3 daemons protected against duplicate spawning
// + Strike Adjustment Engine: Real-time (10s) on /projections
// + HITL Approval: Telegram buttons + Dashboard + iPhone + Cowork MCP
//
// ── SYSTEM 13: NEURAL REGIME CLASSIFIER (March 21, 2026) ──
// Model: CalibratedEnsemble(RandomForest300 + GradientBoosting200)
// CV Accuracy: 95.6% (5-fold stratified)
// Features: 65 (13 base × 5 lags) — RSI, SMA ratios, ROC, volatility, ATH distance
// 4 Regimes: ACCUMULATION | MARKUP | DISTRIBUTION | MARKDOWN
// Current: DISTRIBUTION at 82.2% confidence, MARKDOWN pressure rising (17.8%)
// Phase-Aware Seasonality: Month × Cycle Phase intelligence (bull vs bear table)
// Source: Morgan Stanley Four Seasons + historical BTC cycle data (2015-2026)
// Purpose: AWARENESS LAYER ONLY — does NOT modify v2.8+ entry/exit logic
// Feeds: trader1 alert context, dashboard, Telegram updates, seasonality table
//
// ── CAPITAL DEPLOYMENT PLAN ──
// Phase 1: ~$7,900 (current IBKR) → first v2.8+ entry if signal fires early
// Phase 2: Put proceeds (MSTR $50P + SPY $430P) → roll into v2.8+ on close
// Phase 3: $130,000 (Aug-Oct 2026) → full scale-in for bulk of bull run
// Total: ~$139,650 → all feeds ONE strategy (v2.8+ MSTR LEAP)
//
// USE ON WEEKLY TIMEFRAME (1W chart for MSTR)
// ═══════════════════════════════════════════════════════════════════════

strategy("Rudy v2.8+ MSTR LEAP", overlay=true, default_qty_type=strategy.percent_of_equity,
     default_qty_value=25, initial_capital=100000, commission_value=0.1,
     pyramiding=2, calc_on_every_tick=false)

// ── INPUT GROUPS ──
g_entry   = "Entry Filters"
g_leap    = "LEAP Simulation"
g_exit    = "Exit / Risk Management"
g_adder   = "Trend Adder (Option B)"
g_visual  = "Visual Settings"

// ═══════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════

// Entry
i_sma_period        = input.int(200, "200W SMA Period", minval=50, group=g_entry)
i_green_weeks       = input.int(2, "Green Weeks to Arm", minval=1, maxval=10, group=g_entry)
i_stoch_rsi_thresh  = input.int(70, "StochRSI Entry Threshold", minval=20, maxval=95, group=g_entry)
i_btc_filter        = input.bool(true, "BTC > 200W MA Filter", group=g_entry)
i_btc_symbol        = input.symbol("COINBASE:BTCUSD", "BTC Symbol", group=g_entry)
i_premium_cap       = input.float(1.3, "Premium Cap (x NAV)", step=0.1, group=g_entry, tooltip="Max mNAV premium for entry. Set to 999 to disable.")

// LEAP Simulation
i_leap_mult         = input.float(6.5, "LEAP Multiplier", minval=1, maxval=15, step=0.5, group=g_leap, tooltip="Simulated LEAP leverage. Conservative=3.3x, Balanced=6.5x, Aggressive=8.4x")
i_risk_capital      = input.float(25.0, "Risk Capital %", minval=5, maxval=50, step=5, group=g_leap)

// Exit / Risk
i_initial_floor     = input.float(35.0, "Initial Floor %", minval=10, maxval=60, step=5, group=g_exit, tooltip="Hard stop below entry (base position)")
i_panic_floor       = input.float(-35.0, "Panic Floor (LEAP %)", maxval=0, step=5, group=g_exit, tooltip="Exit if LEAP P&L drops below this while losing")
i_trail_5x          = input.float(40.0, "Trail @ +500% LEAP", minval=10, maxval=60, step=5, group=g_exit)
i_trail_10x         = input.float(35.0, "Trail @ +1000% LEAP", minval=10, maxval=50, step=5, group=g_exit)
i_trail_20x         = input.float(30.0, "Trail @ +2000% LEAP", minval=10, maxval=50, step=5, group=g_exit)
i_trail_50x         = input.float(25.0, "Trail @ +5000% LEAP", minval=5, maxval=40, step=5, group=g_exit)
i_trail_100x        = input.float(15.0, "Trail @ +10000% LEAP", minval=5, maxval=30, step=5, group=g_exit)
i_max_hold           = input.int(120, "Max Hold (weeks)", minval=20, maxval=200, group=g_exit)

// Trend Adder
i_adder_enabled     = input.bool(true, "Enable Trend Adder", group=g_adder)
i_confirm_weeks     = input.int(4, "Golden Cross Confirm Weeks", minval=2, maxval=10, group=g_adder)
i_convergence_pct   = input.float(10.0, "Convergence-Down Exit %", minval=5, maxval=30, step=5, group=g_adder, tooltip="Exit adder when both MAs falling and within this % of each other")
i_adder_capital     = input.float(25.0, "Adder Capital %", minval=5, maxval=50, step=5, group=g_adder)
i_adder_panic       = input.float(-60.0, "Adder Panic Floor (LEAP %)", maxval=0, step=5, group=g_adder)
i_adder_floor       = input.float(45.0, "Adder Initial Floor %", minval=10, maxval=60, step=5, group=g_adder)

// Visual
i_show_sma          = input.bool(true, "Show 200W SMA", group=g_visual)
i_show_ema          = input.bool(true, "Show 50W EMA", group=g_visual)
i_show_signals      = input.bool(true, "Show Entry/Exit Signals", group=g_visual)
i_show_zones        = input.bool(true, "Show Trend Zones", group=g_visual)
i_show_table        = input.bool(true, "Show Status Table", group=g_visual)

// ═══════════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════

// ── Moving Averages ──
sma_200w = ta.sma(close, i_sma_period)
ema_50w  = ta.ema(close, 50)

// ── BTC Data (for filter) ──
btc_close = request.security(i_btc_symbol, "W", close)
btc_200w  = request.security(i_btc_symbol, "W", ta.sma(close, 200))

// ── StochRSI ──
rsi_val    = ta.rsi(close, 14)
rsi_lowest = ta.lowest(rsi_val, 14)
rsi_highest = ta.highest(rsi_val, 14)
stoch_rsi  = rsi_highest != rsi_lowest ? (rsi_val - rsi_lowest) / (rsi_highest - rsi_lowest) * 100 : 50

// ── mNAV Premium (simplified — uses BTC price × approximate holdings / approx shares) ──
// NOTE: This is an approximation. Update holdings/shares from MSTR 8-K filings.
// March 2026: 761,000+ BTC held at avg $75,696/coin, ~390M diluted shares
btc_holdings = year >= 2026 ? 761000.0 : year >= 2025 ? 499226.0 : year >= 2024 ? 446400.0 : year >= 2023 ? 189150.0 : year >= 2022 ? 132500.0 : year >= 2021 ? 124391.0 : year >= 2020 ? 70784.0 : 0.0
diluted_shares = year >= 2026 ? 390000000.0 : year >= 2025 ? 330000000.0 : year >= 2024 ? 182000000.0 : year >= 2023 ? 14500000.0 : year >= 2022 ? 11500000.0 : year >= 2021 ? 11500000.0 : year >= 2020 ? 11500000.0 : 10500000.0
nav_per_share = btc_holdings > 0 and diluted_shares > 0 ? (btc_close * btc_holdings) / diluted_shares : close
mstr_premium = nav_per_share > 0 ? close / nav_per_share : 1.0

// ═══════════════════════════════════════════════════════════════════════
// 200W DIP + RECLAIM LOGIC
// ═══════════════════════════════════════════════════════════════════════

below_200w = close < sma_200w
above_200w = close > sma_200w
green_candle = close > open

// Track dip below 200W
var bool dipped = false
var int green_count = 0
var bool is_armed = false

if below_200w
    dipped := true
    green_count := 0
    is_armed := false

if dipped and above_200w and green_candle
    green_count += 1
else if below_200w
    green_count := 0

if green_count >= i_green_weeks and not is_armed
    is_armed := true

// Reset after sustained bull (allow re-entry next cycle)
if green_count > i_green_weeks + 10
    dipped := false

// ═══════════════════════════════════════════════════════════════════════
// GOLDEN CROSS DETECTION
// ═══════════════════════════════════════════════════════════════════════

golden_cross = ema_50w > sma_200w

// Slopes (compare to 4 weeks ago)
ema_50w_prev  = ema_50w[4]
sma_200w_prev = sma_200w[4]
ema_rising    = ema_50w > ema_50w_prev
sma_rising    = sma_200w > sma_200w_prev
ema_falling   = ema_50w < ema_50w_prev
sma_falling   = sma_200w < sma_200w_prev

// Distance between EMAs
distance_pct = sma_200w > 0 ? ((ema_50w - sma_200w) / sma_200w) * 100 : 0

// Convergence-down: both falling AND close
convergence_down = ema_falling and sma_falling and math.abs(distance_pct) < i_convergence_pct

// Track golden cross weeks
var int gc_weeks = 0
if golden_cross and ema_rising and sma_rising
    gc_weeks += 1
else if not golden_cross
    gc_weeks := 0

gc_confirmed = gc_weeks >= i_confirm_weeks

// ═══════════════════════════════════════════════════════════════════════
// ENTRY FILTERS
// ═══════════════════════════════════════════════════════════════════════

btc_above_200w = not i_btc_filter or (not na(btc_200w) and btc_close > btc_200w)
stoch_rsi_ok   = stoch_rsi < i_stoch_rsi_thresh
premium_ok     = mstr_premium <= i_premium_cap or btc_holdings == 0  // ignore pre-BTC era
btc_era        = year >= 2020

all_entry_filters = is_armed and btc_above_200w and stoch_rsi_ok and premium_ok and btc_era

// ═══════════════════════════════════════════════════════════════════════
// POSITION STATE
// ═══════════════════════════════════════════════════════════════════════

var float entry_price = 0.0
var float position_hwm = 0.0
var float peak_leap_gain = 0.0
var int bars_held = 0
var bool base_open = false
var bool cycle_entered = false

// Trend adder state
var float adder_entry = 0.0
var float adder_hwm = 0.0
var float adder_peak_gain = 0.0
var bool adder_open = false

// ═══════════════════════════════════════════════════════════════════════
// LEAP P&L CALCULATION
// ═══════════════════════════════════════════════════════════════════════

base_stock_gain = entry_price > 0 ? ((close - entry_price) / entry_price) * 100 : 0.0
base_leap_gain  = base_stock_gain * i_leap_mult

hwm_stock_gain  = entry_price > 0 ? ((position_hwm - entry_price) / entry_price) * 100 : 0.0
hwm_leap_gain   = hwm_stock_gain * i_leap_mult

adder_stock_gain = adder_entry > 0 ? ((close - adder_entry) / adder_entry) * 100 : 0.0
adder_leap_gain  = adder_stock_gain * i_leap_mult

// ═══════════════════════════════════════════════════════════════════════
// BASE ENTRY
// ═══════════════════════════════════════════════════════════════════════

base_entry_signal = all_entry_filters and not base_open and not cycle_entered

if base_entry_signal
    strategy.entry("Base", strategy.long, qty=math.floor(strategy.equity * (i_risk_capital / 100) / close))
    entry_price := close
    position_hwm := close
    peak_leap_gain := 0
    bars_held := 0
    base_open := true
    cycle_entered := true

// ═══════════════════════════════════════════════════════════════════════
// TREND ADDER ENTRY
// ═══════════════════════════════════════════════════════════════════════

adder_entry_signal = i_adder_enabled and base_open and gc_confirmed and not adder_open and btc_era

if adder_entry_signal
    strategy.entry("Adder", strategy.long, qty=math.floor(strategy.equity * (i_adder_capital / 100) / close))
    adder_entry := close
    adder_hwm := close
    adder_peak_gain := 0
    adder_open := true

// ═══════════════════════════════════════════════════════════════════════
// POSITION MANAGEMENT (runs every bar when in position)
// ═══════════════════════════════════════════════════════════════════════

if base_open
    bars_held += 1
    position_hwm := math.max(position_hwm, close)
    peak_leap_gain := math.max(peak_leap_gain, hwm_leap_gain)

    // ── Initial Floor ──
    floor_price = entry_price * (1 - i_initial_floor / 100)
    if base_leap_gain < 500 and close < floor_price
        strategy.close_all(comment="FLOOR")
        base_open := false
        adder_open := false
        entry_price := 0
        adder_entry := 0
        cycle_entered := false

    // ── Panic Floor (losers only) ──
    if base_stock_gain < 0 and base_leap_gain <= i_panic_floor
        strategy.close_all(comment="PANIC")
        base_open := false
        adder_open := false
        entry_price := 0
        adder_entry := 0
        cycle_entered := false

    // ── Laddered Trailing Stops ──
    trail_pct = peak_leap_gain >= 10000 ? i_trail_100x : peak_leap_gain >= 5000 ? i_trail_50x : peak_leap_gain >= 2000 ? i_trail_20x : peak_leap_gain >= 1000 ? i_trail_10x : peak_leap_gain >= 500 ? i_trail_5x : 0.0

    if trail_pct > 0
        trail_stop = position_hwm * (1 - trail_pct / 100)
        if close < trail_stop
            strategy.close_all(comment="TRAIL")
            base_open := false
            adder_open := false
            entry_price := 0
            adder_entry := 0
            cycle_entered := false

    // ── Max Hold ──
    if bars_held >= i_max_hold
        strategy.close_all(comment="MAX_HOLD")
        base_open := false
        adder_open := false
        entry_price := 0
        adder_entry := 0
        cycle_entered := false

// ═══════════════════════════════════════════════════════════════════════
// TREND ADDER EXIT (independent of base)
// ═══════════════════════════════════════════════════════════════════════

if adder_open and adder_entry > 0
    adder_hwm := math.max(adder_hwm, close)
    adder_hwm_sg = ((adder_hwm - adder_entry) / adder_entry) * 100
    adder_peak_gain := math.max(adder_peak_gain, adder_hwm_sg * i_leap_mult)

    // Convergence-down exit
    if convergence_down
        strategy.close("Adder", comment="CONVERGE_DN")
        adder_open := false
        adder_entry := 0
        gc_weeks := 0

    // Adder panic floor
    if adder_stock_gain < 0 and adder_leap_gain <= i_adder_panic
        strategy.close("Adder", comment="ADDER_PANIC")
        adder_open := false
        adder_entry := 0

    // Adder initial floor
    adder_floor_price = adder_entry * (1 - i_adder_floor / 100)
    if adder_leap_gain < 500 and close < adder_floor_price
        strategy.close("Adder", comment="ADDER_FLOOR")
        adder_open := false
        adder_entry := 0

    // Adder safety trails (minimal)
    adder_trail = adder_peak_gain >= 10000 ? 25.0 : adder_peak_gain >= 5000 ? 35.0 : 0.0
    if adder_trail > 0
        adder_stop = adder_hwm * (1 - adder_trail / 100)
        if close < adder_stop
            strategy.close("Adder", comment="ADDER_TRAIL")
            adder_open := false
            adder_entry := 0

// Reset cycle flag when price dips below 200W again
if below_200w and not base_open
    cycle_entered := false

// ═══════════════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════════════

// Moving averages
plot(i_show_sma ? sma_200w : na, "200W SMA", color=color.new(color.orange, 0), linewidth=2)
plot(i_show_ema ? ema_50w : na, "50W EMA", color=color.new(color.blue, 0), linewidth=2)

// Golden cross zone fill
p_ema = plot(i_show_zones ? ema_50w : na, display=display.none)
p_sma = plot(i_show_zones ? sma_200w : na, display=display.none)
fill(p_ema, p_sma, color=golden_cross ? color.new(color.green, 85) : color.new(color.red, 90), title="GC Zone")

// Entry signals
plotshape(i_show_signals and base_entry_signal, "Base Entry", shape.triangleup,
     location.belowbar, color.new(color.green, 0), size=size.large)
plotshape(i_show_signals and adder_entry_signal, "Adder Entry", shape.diamond,
     location.belowbar, color.new(color.teal, 0), size=size.normal)

// Armed state
bgcolor(is_armed and not base_open ? color.new(color.green, 92) : na, title="Armed BG")

// Convergence-down warning
plotshape(i_show_signals and convergence_down and adder_open, "Converge Down", shape.xcross,
     location.abovebar, color.new(color.red, 0), size=size.small)

// ═══════════════════════════════════════════════════════════════════════
// STATUS TABLE
// ═══════════════════════════════════════════════════════════════════════

if i_show_table and barstate.islast
    var table tbl = table.new(position.top_right, 2, 14, bgcolor=color.new(color.black, 20),
         border_width=1, border_color=color.gray)

    table.cell(tbl, 0, 0, "RUDY v2.8+", text_color=color.white, text_size=size.normal, bgcolor=color.new(#1a73e8, 0))
    table.cell(tbl, 1, 0, base_open ? (adder_open ? "BASE + ADDER" : "BASE ONLY") : (is_armed ? "ARMED" : "SCANNING"), text_color=color.white, text_size=size.normal, bgcolor=base_open ? color.new(color.green, 20) : is_armed ? color.new(color.orange, 20) : color.new(color.gray, 20))

    table.cell(tbl, 0, 1, "200W SMA", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 1, not na(sma_200w) ? str.tostring(sma_200w, "#.##") : "N/A", text_color=above_200w ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 2, "50W EMA", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 2, not na(ema_50w) ? str.tostring(ema_50w, "#.##") : "N/A", text_color=golden_cross ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 3, "Golden Cross", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 3, golden_cross ? "YES (" + str.tostring(gc_weeks) + "w)" : "NO", text_color=golden_cross ? color.green : color.gray, text_size=size.small)

    table.cell(tbl, 0, 4, "Distance %", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 4, str.tostring(distance_pct, "#.#") + "%", text_color=distance_pct > 0 ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 5, "StochRSI", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 5, str.tostring(stoch_rsi, "#.#"), text_color=stoch_rsi_ok ? color.green : color.orange, text_size=size.small)

    table.cell(tbl, 0, 6, "Premium", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 6, btc_holdings > 0 ? str.tostring(mstr_premium, "#.##") + "x" : "N/A", text_color=premium_ok ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 7, "BTC > 200W", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 7, btc_above_200w ? "YES" : "NO", text_color=btc_above_200w ? color.green : color.red, text_size=size.small)

    // Position info
    table.cell(tbl, 0, 8, "─── Position ───", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 8, "", text_size=size.small)

    table.cell(tbl, 0, 9, "Base LEAP P&L", text_color=color.white, text_size=size.small)
    base_pnl_str = base_open ? (base_leap_gain >= 0 ? "+" + str.tostring(base_leap_gain, "#.#") + "%" : str.tostring(base_leap_gain, "#.#") + "%") : "—"
    table.cell(tbl, 1, 9, base_pnl_str, text_color=base_leap_gain > 0 ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 10, "Adder LEAP P&L", text_color=color.white, text_size=size.small)
    adder_pnl_str = adder_open ? (adder_leap_gain >= 0 ? "+" + str.tostring(adder_leap_gain, "#.#") + "%" : str.tostring(adder_leap_gain, "#.#") + "%") : "—"
    table.cell(tbl, 1, 10, adder_pnl_str, text_color=adder_leap_gain > 0 ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 11, "Peak LEAP Gain", text_color=color.white, text_size=size.small)
    peak_str = base_open ? "+" + str.tostring(peak_leap_gain, "#.#") + "%" : "—"
    table.cell(tbl, 1, 11, peak_str, text_color=color.white, text_size=size.small)

    trail_display = peak_leap_gain >= 10000 ? str.tostring(i_trail_100x) + "%" : peak_leap_gain >= 5000 ? str.tostring(i_trail_50x) + "%" : peak_leap_gain >= 2000 ? str.tostring(i_trail_20x) + "%" : peak_leap_gain >= 1000 ? str.tostring(i_trail_10x) + "%" : peak_leap_gain >= 500 ? str.tostring(i_trail_5x) + "%" : "None"

    table.cell(tbl, 0, 12, "Active Trail", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 12, trail_display, text_color=color.orange, text_size=size.small)

    table.cell(tbl, 0, 13, "Bars Held", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 13, base_open ? str.tostring(bars_held) + "w" : "—", text_color=color.white, text_size=size.small)

// ═══════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════

alertcondition(is_armed and not is_armed[1], "Rudy Armed", "RUDY ARMED: 200W dip+reclaim confirmed. Watching for entry confluence.")
alertcondition(base_entry_signal, "Base Entry", "RUDY BASE ENTRY: All filters passed. Deploying 25% capital.")
alertcondition(adder_entry_signal, "Trend Adder Entry", "RUDY TREND ADDER: Golden cross confirmed {{i_confirm_weeks}}w. Adding {{i_adder_capital}}% capital.")
alertcondition(convergence_down and adder_open, "Convergence Down", "RUDY CONVERGENCE DOWN: Both MAs falling + converging. Adder exit signal.")
alertcondition(golden_cross and not golden_cross[1], "Golden Cross", "GOLDEN CROSS: 50W EMA crossed above 200W SMA.")
alertcondition(not golden_cross and golden_cross[1], "Death Cross", "DEATH CROSS: 50W EMA crossed below 200W SMA.")
