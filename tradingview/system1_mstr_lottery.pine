// Rudy v2.0 — System 1: MSTR Lottery Signal Generator
// Constitution v50.0
// Tickers: MSTR, IBIT only
// Strategy: Deep OTM calls, quarterly entries, $100k allocation

//@version=5
indicator("Rudy System 1 — MSTR Lottery", overlay=true, max_labels_count=50)

// === INPUTS ===
rsiLen      = input.int(14, "RSI Length")
rsiOversold = input.int(30, "RSI Oversold Threshold")
volMult     = input.float(2.0, "Volume Spike Multiplier")
volAvgLen   = input.int(20, "Volume Average Length")
macdFast    = input.int(12, "MACD Fast")
macdSlow    = input.int(26, "MACD Slow")
macdSignal  = input.int(9, "MACD Signal")
quarterWindow = input.int(10, "Quarter Entry Window (trading days)")

// === CALCULATIONS ===
rsi = ta.rsi(close, rsiLen)
[macdLine, signalLine, hist] = ta.macd(close, macdFast, macdSlow, macdSignal)
macdCross = ta.crossover(macdLine, signalLine)

avgVol = ta.sma(volume, volAvgLen)
volSpike = volume > avgVol * volMult

// Quarterly timing — first 2 weeks of Jan, Apr, Jul, Oct
isQuarterStart = (month == 1 or month == 4 or month == 7 or month == 10) and dayofmonth <= 14

// === SIGNAL LOGIC ===
// Primary: RSI oversold + MACD bullish crossover + volume spike
primarySignal = rsi < rsiOversold and macdCross and volSpike

// Secondary: RSI oversold + MACD crossover (no volume requirement)
secondarySignal = rsi < rsiOversold and macdCross and not volSpike

// Quarterly filter — signals strongest during quarter entry window
quarterSignal = primarySignal and isQuarterStart
offQuarterSignal = primarySignal and not isQuarterStart

// === TICKER VALIDATION ===
validTicker = syminfo.ticker == "MSTR" or syminfo.ticker == "IBIT" or syminfo.ticker == "MSTR.O" or syminfo.ticker == "IBIT.O"

if not validTicker
    label.new(bar_index, high, "WARNING: System 1 is for MSTR/IBIT only!",
              color=color.red, textcolor=color.white, style=label.style_label_down, size=size.large)

// === PLOT SIGNALS ===
// Green up arrow = primary signal during quarter window (strongest)
plotshape(quarterSignal and validTicker, title="Quarter Entry",
          style=shape.triangleup, location=location.belowbar,
          color=color.lime, size=size.large, text="S1 ENTRY")

// Yellow up arrow = primary signal outside quarter window
plotshape(offQuarterSignal and validTicker, title="Off-Quarter Signal",
          style=shape.triangleup, location=location.belowbar,
          color=color.yellow, size=size.normal, text="S1")

// Small blue arrow = secondary signal (weaker)
plotshape(secondarySignal and validTicker, title="Secondary Signal",
          style=shape.triangleup, location=location.belowbar,
          color=color.aqua, size=size.small, text="s1")

// === RSI BACKGROUND ===
bgcolor(rsi < rsiOversold ? color.new(color.green, 90) : na, title="RSI Oversold Zone")

// === INFO TABLE ===
var table infoTable = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "RUDY S1", text_color=color.lime, text_size=size.normal)
    table.cell(infoTable, 1, 0, "MSTR Lottery", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 0, 1, "RSI", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(rsi, "#.0"), text_color=rsi < rsiOversold ? color.lime : color.white, text_size=size.small)
    table.cell(infoTable, 0, 2, "MACD", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 2, macdLine > signalLine ? "BULLISH" : "BEARISH", text_color=macdLine > signalLine ? color.lime : color.red, text_size=size.small)
    table.cell(infoTable, 0, 3, "Volume", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 3, volSpike ? "SPIKE" : "Normal", text_color=volSpike ? color.yellow : color.white, text_size=size.small)
    table.cell(infoTable, 0, 4, "Quarter", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 4, isQuarterStart ? "ACTIVE" : "Off-Cycle", text_color=isQuarterStart ? color.lime : color.orange, text_size=size.small)
    table.cell(infoTable, 0, 5, "Ticker", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 5, validTicker ? "VALID" : "INVALID", text_color=validTicker ? color.lime : color.red, text_size=size.small)

// === ALERTS ===
// Primary quarterly entry — strongest signal
alertcondition(quarterSignal and validTicker, title="S1 Quarter Entry",
     message='{"system": "system1", "ticker": "{{ticker}}", "action": "BUY", "price": {{close}}, "timestamp": "{{time}}", "message": "System 1 quarterly entry — RSI oversold + MACD cross + volume spike"}')

// Off-quarter primary signal
alertcondition(offQuarterSignal and validTicker, title="S1 Off-Quarter Signal",
     message='{"system": "system1", "ticker": "{{ticker}}", "action": "BUY", "price": {{close}}, "timestamp": "{{time}}", "message": "System 1 off-quarter signal — RSI oversold + MACD cross + volume spike"}')

// Secondary signal (weaker)
alertcondition(secondarySignal and validTicker, title="S1 Secondary Signal",
     message='{"system": "system1", "ticker": "{{ticker}}", "action": "BUY", "price": {{close}}, "timestamp": "{{time}}", "message": "System 1 secondary signal — RSI oversold + MACD cross"}')
